---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { en } from '../../i18n/en';
import '../../styles/global.css';

const t = en;

const posts = [
  {
    slug: '/blog/how-many-calories-should-i-eat',
    title: 'How Many Calories Should I Eat Per Day?',
    excerpt: 'Most people guess their calorie needs — and get it wrong by 30–40%. Here\'s how to find your actual daily target based on your body and goal.',
    category: 'Nutrition Basics',
    readTime: '6 min read',
    icon: 'local_fire_department',
    iconColor: 'text-primary bg-orange-50',
    date: 'April 2025',
  },
  {
    slug: '/blog/what-is-bmi',
    title: 'What Is BMI? How to Use It (and When to Ignore It)',
    excerpt: 'BMI is useful as a quick health screen — but it has real blind spots. Learn what your number means, what it misses, and what to track instead.',
    category: 'Nutrition Basics',
    readTime: '5 min read',
    icon: 'monitor_weight',
    iconColor: 'text-blue-500 bg-blue-50',
    date: 'April 2025',
  },
  {
    slug: '/blog/best-foods-for-muscle-gain',
    title: 'Best Foods for Muscle Gain: What to Actually Eat',
    excerpt: 'Building lean muscle isn\'t about eating more of anything — it\'s about eating the right things. A practical food list and sample day for lifters.',
    category: 'Nutrition for Training',
    readTime: '7 min read',
    icon: 'fitness_center',
    iconColor: 'text-emerald-500 bg-emerald-50',
    date: 'April 2025',
  },
  {
    slug: '/blog/how-to-lose-weight-without-counting-calories',
    title: 'How to Lose Weight Without Counting Calories',
    excerpt: 'Calorie counting works — but it isn\'t the only way. Seven habits that create a natural deficit and stick around long after motivation fades.',
    category: 'Weight Loss',
    readTime: '7 min read',
    icon: 'self_improvement',
    iconColor: 'text-rose-500 bg-rose-50',
    date: 'April 2025',
  },
  {
    slug: '/blog/caffeine-supplement-guide',
    title: 'Caffeine: The Complete Supplement Guide',
    excerpt: 'The world\'s most studied performance drug. Dosing, timing, tolerance management, and how to pair it for maximum effect — without the crash.',
    category: 'Supplements',
    readTime: '7 min read',
    icon: 'coffee',
    iconColor: 'text-amber-600 bg-amber-50',
    date: 'April 2025',
  },
  {
    slug: '/blog/creatine-supplement-guide',
    title: 'Creatine: The Complete Guide',
    excerpt: 'Over 500 studies back it. Here\'s how it works, why loading is optional, which form to buy, and every myth debunked in plain language.',
    category: 'Supplements',
    readTime: '6 min read',
    icon: 'bolt',
    iconColor: 'text-blue-600 bg-blue-50',
    date: 'April 2025',
  },
  {
    slug: '/blog/protein-powder-guide',
    title: 'Protein Powder: Which Type Is Right for You?',
    excerpt: 'Whey, casein, plant, collagen — a clear breakdown of every type, who needs each one, and what to look for (and avoid) on the label.',
    category: 'Supplements',
    readTime: '7 min read',
    icon: 'blender',
    iconColor: 'text-emerald-600 bg-emerald-50',
    date: 'April 2025',
  },
  {
    slug: '/blog/best-supplements-guide',
    title: 'The Best Supplements: An Honest Guide',
    excerpt: 'No hype, no purchased research. An evidence-based breakdown of the top 5 supplements worth your money — what they do, the right dose, and what to skip.',
    category: 'Supplements',
    readTime: '8 min read',
    icon: 'science',
    iconColor: 'text-blue-600 bg-blue-50',
    date: 'April 2025',
  },
  {
    slug: '/blog/mass-gainer-guide',
    title: 'Mass Gainers: Who Needs Them & How to Use Them',
    excerpt: 'A mass gainer can be a legitimate tool — or an overpriced bag of sugar. Find out if you actually need one, how to pick one, and the cheaper DIY alternative.',
    category: 'Supplements',
    readTime: '6 min read',
    icon: 'monitor_weight',
    iconColor: 'text-violet-600 bg-violet-50',
    date: 'April 2025',
  },
  {
    slug: '/blog/5x5-workout-program',
    title: '5×5 Workout Program: The Complete Guide',
    excerpt: 'Three days a week. Five compound lifts. Add weight every session. The simplest beginner program in the gym — and the most effective one for building muscle fast.',
    category: 'Training Programs',
    readTime: '10 min read',
    icon: 'fitness_center',
    iconColor: 'text-red-600 bg-red-50',
    date: 'April 2025',
  },
  {
    slug: '/blog/push-pull-legs-program',
    title: 'Push Pull Legs: The Complete Program Guide',
    excerpt: 'The most popular training split for intermediate lifters, fully explained. Schedule options, sample workouts for all three days, and the one rule that makes it work.',
    category: 'Training Programs',
    readTime: '8 min read',
    icon: 'sports_gymnastics',
    iconColor: 'text-red-600 bg-red-50',
    date: 'April 2025',
  },
  {
    slug: '/blog/arnold-schwarzenegger-workout-program',
    title: "Arnold's Workout Program: The Golden Era Split",
    excerpt: 'Seven Mr. Olympia titles, six days a week, twice a day. Here\'s Arnold\'s full training program, his philosophy, and how to adapt it without overtraining.',
    category: 'Training Programs',
    readTime: '8 min read',
    icon: 'emoji_events',
    iconColor: 'text-slate-700 bg-slate-100',
    date: 'April 2025',
  },
  {
    slug: '/blog/protein-pancake-recipe',
    title: 'High-Protein Pancake Recipe: 40g Protein, 5 Minutes',
    excerpt: '40g protein, fluffy texture, 5-minute prep. The base recipe, five tested variations with full macros, and the two mistakes that make protein pancakes rubbery.',
    category: 'Recipes',
    readTime: '5 min read',
    icon: 'breakfast_dining',
    iconColor: 'text-yellow-600 bg-yellow-50',
    date: 'April 2025',
  },
  {
    slug: '/blog/fitness-for-beginners',
    title: 'Fitness for Beginners: The Complete Roadmap',
    excerpt: 'What is fitness, how does it differ from bodybuilding, and how do you actually start? A clear roadmap covering goals, training, nutrition, and the most common beginner myths.',
    category: 'Training Programs',
    readTime: '10 min read',
    icon: 'directions_run',
    iconColor: 'text-primary bg-orange-50',
    date: 'April 2025',
  },
];

const categories = ['All', ...Array.from(new Set(posts.map(p => p.category)))];
---

<Layout
  title="SlayCal Blog — Nutrition, Health & Fitness Guides"
  description="Free guides on nutrition, calorie tracking, BMI, macros, supplements, training programs, and building healthy habits. Written for real people, not textbooks."
  keywords="nutrition blog, calorie guide, BMI guide, macro tips, healthy eating, weight loss tips, supplements guide, workout programs, SlayCal blog"
  lang="en"
  canonicalPath="/blog"
>
  <Header t={t} lang="en" currentPath="/blog" />

  <main id="main-content">

    <!-- ── HERO ─────────────────────────────────────────────────── -->
    <section class="relative overflow-hidden bg-background-light px-6 pt-20 pb-12 lg:px-20 lg:pt-28 lg:pb-16">
      <div class="blob-bg absolute -top-40 left-1/2 -translate-x-1/2 w-[600px] h-[600px] opacity-30 pointer-events-none" aria-hidden="true"></div>
      <div class="relative mx-auto max-w-4xl">
        <div class="inline-flex items-center gap-2 rounded-full bg-primary/10 px-4 py-1.5 mb-5">
          <span class="material-symbols-outlined text-primary text-base leading-none">menu_book</span>
          <span class="text-sm font-semibold text-primary">The SlayCal Blog</span>
        </div>
        <h1 class="text-4xl font-bold text-slate-900 lg:text-5xl leading-tight tracking-tight">
          Nutrition & Fitness,<br/>
          <span class="text-primary">Made Simple</span>
        </h1>
        <p class="mt-4 text-lg text-slate-500 max-w-xl leading-relaxed">
          No fluff. No pseudoscience. Practical guides on nutrition, supplements, and training — for people who want results, not information overload.
        </p>
      </div>
    </section>

    <!-- ── CATEGORY FILTER ─────────────────────────────────────────── -->
    <section class="bg-background-light px-6 pb-6 lg:px-20">
      <div class="mx-auto max-w-4xl">
        <div class="flex flex-wrap gap-2" role="group" aria-label="Filter posts by category">
          {categories.map(cat => (
            <button
              data-category={cat}
              class={`category-btn px-4 py-2 rounded-full text-sm font-semibold border transition-all focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary ${cat === 'All' ? 'bg-primary text-white border-primary' : 'bg-white text-slate-600 border-slate-200 hover:border-primary/40 hover:text-primary'}`}
            >
              {cat}
            </button>
          ))}
        </div>
      </div>
    </section>

    <!-- ── POSTS GRID ─────────────────────────────────────────────── -->
    <section class="bg-background-light px-6 pb-20 lg:px-20" aria-labelledby="posts-title">
      <div class="mx-auto max-w-4xl">
        <h2 id="posts-title" class="sr-only">Blog posts</h2>
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2" id="posts-grid">
          {posts.map(({ slug, title, excerpt, category, readTime, icon, iconColor, date }) => (
            <a
              href={slug}
              data-post-category={category}
              class="post-card group flex flex-col rounded-3xl bg-white border border-slate-100 p-7 hover:border-primary/30 hover:-translate-y-1 hover:shadow-lg transition-all duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
            >
              <div class="flex items-center justify-between mb-5">
                <div class={`flex h-11 w-11 items-center justify-center rounded-2xl ${iconColor}`}>
                  <span class="material-symbols-outlined text-xl">{icon}</span>
                </div>
                <span class="text-xs text-slate-400">{date}</span>
              </div>

              <span class="text-xs font-bold uppercase tracking-wider text-primary mb-2">{category}</span>
              <h3 class="text-lg font-bold text-slate-900 leading-snug mb-3 group-hover:text-primary transition-colors">{title}</h3>
              <p class="text-sm text-slate-500 leading-relaxed flex-1">{excerpt}</p>

              <div class="mt-5 flex items-center justify-between">
                <span class="text-xs text-slate-400 flex items-center gap-1">
                  <span class="material-symbols-outlined text-sm">schedule</span>
                  {readTime}
                </span>
                <span class="text-sm font-semibold text-primary flex items-center gap-1 group-hover:gap-2 transition-all">
                  Read more <span class="material-symbols-outlined text-base">arrow_forward</span>
                </span>
              </div>
            </a>
          ))}
        </div>

        <p id="no-posts-msg" class="hidden text-center text-slate-400 text-sm py-16">No posts in this category yet.</p>
      </div>
    </section>

    <!-- ── APP CTA ────────────────────────────────────────────────── -->
    <section class="relative overflow-hidden bg-gradient-to-br from-primary via-accent to-amber-400 px-6 py-16 lg:px-20">
      <div class="relative mx-auto max-w-3xl text-center">
        <h2 class="text-2xl font-bold text-white lg:text-3xl">Put the knowledge to work.</h2>
        <p class="mt-3 text-white/80 max-w-md mx-auto text-sm leading-relaxed">SlayCal tracks your calories, macros, and BMI automatically. No manual logging — just scan and go.</p>
        <div class="mt-6 flex flex-wrap justify-center gap-3">
          <a href="#" class="flex items-center gap-2 px-6 py-3 rounded-2xl bg-white text-slate-900 font-bold text-sm hover:bg-slate-50 transition-all shadow-lg" data-analytics-store="ios" data-analytics-placement="blog_index_cta">
            <svg class="w-5 h-5 fill-slate-900 shrink-0" viewBox="0 0 24 24"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
            App Store
          </a>
          <a href="#" class="flex items-center gap-2 px-6 py-3 rounded-2xl bg-white/15 border border-white/30 text-white font-bold text-sm hover:bg-white/25 transition-all" data-analytics-store="android" data-analytics-placement="blog_index_cta">
            <svg class="w-5 h-5 fill-white shrink-0" viewBox="0 0 24 24"><path d="M3.18 23.76A2 2 0 0 1 2 22V2a2 2 0 0 1 1.18-1.76l11.65 11.76zm15.49-8.58L16.07 13.5 3.64.05l.88-.05 14.15 7.87a2 2 0 0 1 0 3.31zM3.64 23.95 16.07 10.5l2.6 1.55-14.15 7.87z"/></svg>
            Google Play
          </a>
        </div>
      </div>
    </section>

  </main>

  <Footer t={t} lang="en" />
</Layout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.category-btn');
  const cards = document.querySelectorAll<HTMLElement>('.post-card');
  const noPostsMsg = document.getElementById('no-posts-msg');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const selected = btn.dataset.category ?? 'All';

      buttons.forEach(b => {
        if (b.dataset.category === selected) {
          b.classList.add('bg-primary', 'text-white', 'border-primary');
          b.classList.remove('bg-white', 'text-slate-600', 'border-slate-200');
        } else {
          b.classList.remove('bg-primary', 'text-white', 'border-primary');
          b.classList.add('bg-white', 'text-slate-600', 'border-slate-200');
        }
      });

      let visibleCount = 0;
      cards.forEach(card => {
        const match = selected === 'All' || card.dataset.postCategory === selected;
        card.style.display = match ? '' : 'none';
        if (match) visibleCount++;
      });

      if (noPostsMsg) {
        noPostsMsg.classList.toggle('hidden', visibleCount > 0);
      }
    });
  });
</script>
