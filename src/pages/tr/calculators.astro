---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { tr } from '../../i18n/tr';
import '../../styles/global.css';

const t = tr;

const calculators = [
  { slug: '/tr/bmi-calculator', icon: 'monitor_weight', title: 'VKİ Hesaplayıcı', description: 'Boyunuz için kilonuzun sağlıklı aralıkta olup olmadığını öğrenin.', benefit: 'Vücut Kitle İndeksinizi saniyeler içinde öğrenin.', color: 'from-blue-50 to-indigo-50', iconColor: 'text-blue-500', borderColor: 'border-blue-100', tag: 'En popüler' },
  { slug: '/tr/calorie-calculator', icon: 'local_fire_department', title: 'Kalori Hesaplayıcı', description: 'Hedefinize göre kişiselleştirilmiş günlük kalori hedefini bulun.', benefit: 'Azaltma, artırma veya koruma için doğru miktarı yiyin.', color: 'from-orange-50 to-amber-50', iconColor: 'text-primary', borderColor: 'border-orange-100', tag: 'Kilo vermek için' },
  { slug: '/tr/macro-calculator', icon: 'pie_chart', title: 'Makro Hesaplayıcı', description: 'Kalorilerinizi protein, karbonhidrat ve yağ hedeflerine bölün.', benefit: 'Vücudunuza özel bir makro dağılımı elde edin.', color: 'from-green-50 to-emerald-50', iconColor: 'text-emerald-500', borderColor: 'border-green-100', tag: 'Fitness için' },
  { slug: '/tr/body-fat-calculator', icon: 'straighten', title: 'Vücut Yağ Hesaplayıcı', description: 'Basit ölçümlerle vücut yağ yüzdenizi tahmin edin.', benefit: 'Sadece tartıyı değil, gerçek vücut kompozisyonunuzu anlayın.', color: 'from-purple-50 to-violet-50', iconColor: 'text-violet-500', borderColor: 'border-purple-100', tag: 'Sporcular için' },
];
---

<Layout
  title="Ücretsiz Sağlık Hesaplayıcıları — VKİ, Kalori, Makro & Vücut Yağı | SlayCal"
  description="VKİ, günlük kalori, makro hedefleri ve vücut yağ yüzdenizi saniyeler içinde hesaplayın. Ücretsiz çevrimiçi sağlık hesaplayıcıları."
  keywords="VKİ hesaplayıcı, kalori hesaplayıcı, makro hesaplayıcı, vücut yağ hesaplayıcı, ücretsiz sağlık araçları"
  lang="tr"
  canonicalPath="/tr/calculators"
>
  <Header t={t} lang="tr" currentPath="/calculators" />

  <main id="main-content">

    <section class="relative overflow-hidden bg-background-light px-6 pt-24 pb-16 lg:px-20 lg:pt-32 lg:pb-20">
      <div class="blob-bg absolute -top-40 left-1/2 -translate-x-1/2 w-[700px] h-[700px] opacity-30 pointer-events-none" aria-hidden="true"></div>
      <div class="relative mx-auto max-w-4xl text-center">
        <div class="inline-flex items-center gap-2 rounded-full bg-primary/10 px-4 py-1.5 mb-6">
          <span class="material-symbols-outlined text-primary text-base leading-none">calculate</span>
          <span class="text-sm font-semibold text-primary">Ücretsiz · Kayıt gerekmez · Anında sonuç</span>
        </div>
        <h1 class="text-4xl font-bold text-slate-900 lg:text-6xl leading-tight tracking-tight">
          Gerçek Sonuçlar için<br/><span class="text-primary">Ücretsiz Sağlık Hesaplayıcıları</span>
        </h1>
        <p class="mt-6 text-lg text-slate-500 max-w-2xl mx-auto leading-relaxed">
          VKİ, kalori, makro, vücut yağı — sağlığınız için gerçekten önemli olan sayıları öğrenin. Her hesaplayıcı 60 saniyeden kısa sürer.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-3">
          <a href="#calculators" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-primary text-white font-semibold shadow-lg shadow-primary/25 hover:bg-accent hover:-translate-y-0.5 transition-all">
            <span class="material-symbols-outlined text-base leading-none">arrow_downward</span>
            Hesaplayıcıları keşfet
          </a>
        </div>
      </div>
    </section>

    <section id="calculators" class="bg-background-light px-6 py-16 lg:px-20">
      <div class="mx-auto max-w-6xl">
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {calculators.map(({ slug, icon, title, description, benefit, color, iconColor, borderColor, tag }) => (
            <a href={slug} class={`group relative flex flex-col rounded-2xl border ${borderColor} bg-gradient-to-br ${color} p-6 hover:-translate-y-1 hover:shadow-lg transition-all duration-200`}>
              {tag && <span class="absolute top-4 right-4 text-[10px] font-bold uppercase tracking-wider text-primary bg-primary/10 px-2 py-0.5 rounded-full">{tag}</span>}
              <div class="mb-4"><span class={`material-symbols-outlined text-4xl ${iconColor}`}>{icon}</span></div>
              <h3 class="text-lg font-bold text-slate-900 leading-tight">{title}</h3>
              <p class="mt-2 text-sm text-slate-500 leading-snug flex-1">{description}</p>
              <div class="mt-4 flex items-start gap-2">
                <span class="material-symbols-outlined text-base text-primary mt-0.5 shrink-0">lightbulb</span>
                <p class="text-xs text-slate-600 leading-snug">{benefit}</p>
              </div>
              <div class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-primary group-hover:gap-2.5 transition-all">
                Hesaplayıcıyı Kullan <span class="material-symbols-outlined text-base leading-none">arrow_forward</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="relative overflow-hidden bg-gradient-to-br from-primary via-accent to-amber-400 px-6 py-20 lg:px-20">
      <div class="relative mx-auto max-w-3xl text-center">
        <h2 class="text-3xl font-bold text-white lg:text-4xl leading-tight">Sayıları bil. Her gün ulaş.</h2>
        <p class="mt-4 text-white/80 max-w-xl mx-auto leading-relaxed">SlayCal, öğünlerinizi tarar ve sonuçlarınızı kişisel hedeflerinizle gerçek zamanlı olarak karşılaştırır.</p>
        <div class="mt-8 flex flex-wrap justify-center gap-4">
          <a href="#" class="flex items-center gap-2 px-7 py-3.5 rounded-2xl bg-white text-slate-900 font-bold hover:bg-slate-50 transition-all shadow-xl" data-analytics-store="ios" data-analytics-placement="tr_calculators_cta">
            <svg class="w-5 h-5 fill-slate-900 shrink-0" viewBox="0 0 24 24"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
            iOS'ta Ücretsiz İndir
          </a>
          <a href="#" class="flex items-center gap-2 px-7 py-3.5 rounded-2xl bg-white/15 border-2 border-white/30 text-white font-bold hover:bg-white/25 transition-all" data-analytics-store="android" data-analytics-placement="tr_calculators_cta">
            <svg class="w-5 h-5 fill-white shrink-0" viewBox="0 0 24 24"><path d="M3.18 23.76A2 2 0 0 1 2 22V2a2 2 0 0 1 1.18-1.76l11.65 11.76zm15.49-8.58L16.07 13.5 3.64.05l.88-.05 14.15 7.87a2 2 0 0 1 0 3.31zM3.64 23.95 16.07 10.5l2.6 1.55-14.15 7.87z"/></svg>
            Google Play'den Al
          </a>
        </div>
      </div>
    </section>

  </main>

  <Footer t={t} lang="tr" />
</Layout>
