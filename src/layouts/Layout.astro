---
const SITE_URL = 'https://slaycal.com';

interface Props {
  title: string;
  description: string;
  keywords?: string;
  lang?: string;
  ogLocale?: string;
  canonicalPath?: string;
  alternatePath?: string;
  alternateLang?: string;
}

const {
  title,
  description,
  keywords = 'AI nutrition app, calorie tracker, macro tracker, meal scanner, recipe generator, SlayCal',
  lang = 'en',
  ogLocale = 'en_US',
  canonicalPath = '/',
  alternatePath,
  alternateLang,
} = Astro.props;

const canonicalUrl = `${SITE_URL}${canonicalPath}`;
const alternateUrl = alternatePath ? `${SITE_URL}${alternatePath}` : null;
const ogImageUrl = `${SITE_URL}/og-image.png`;

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${SITE_URL}/#website`,
      url: SITE_URL,
      name: 'SlayCal',
      description:
        'AI-powered nutrition tracking and recipe generation app for iOS and Android.',
      potentialAction: {
        '@type': 'SearchAction',
        target: { '@type': 'EntryPoint', urlTemplate: `${SITE_URL}/?q={search_term_string}` },
        'query-input': 'required name=search_term_string',
      },
    },
    {
      '@type': 'MobileApplication',
      '@id': `${SITE_URL}/#app`,
      name: 'SlayCal',
      description:
        'AI-powered nutrition coach and personal chef app. Scan meals for instant nutrition data, scan ingredients for recipes, track macros, water and weight.',
      url: SITE_URL,
      applicationCategory: 'HealthApplication',
      operatingSystem: 'iOS, Android',
      offers: {
        '@type': 'Offer',
        price: '0',
        priceCurrency: 'USD',
      },
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: '4.8',
        reviewCount: '2400',
      },
    },
    {
      '@type': 'Organization',
      '@id': `${SITE_URL}/#organization`,
      name: 'SlayCal',
      url: SITE_URL,
      logo: {
        '@type': 'ImageObject',
        url: `${SITE_URL}/logo.svg`,
      },
    },
  ],
});
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="SlayCal" />

    <!-- Canonical & hreflang -->
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={`${SITE_URL}/`} />
    <link rel="alternate" hreflang="tr" href={`${SITE_URL}/tr/`} />
    <link rel="alternate" hreflang="x-default" href={`${SITE_URL}/`} />
    {alternateUrl && alternateLang && (
      <link rel="alternate" hreflang={alternateLang} href={alternateUrl} />
    )}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="SlayCal" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="SlayCal – AI Nutrition Coach & Personal Chef App" />
    <meta property="og:locale" content={ogLocale} />
    {ogLocale === 'en_US' && <meta property="og:locale:alternate" content="tr_TR" />}
    {ogLocale === 'tr_TR' && <meta property="og:locale:alternate" content="en_US" />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content="SlayCal – AI Nutrition Coach & Personal Chef App" />

    <!-- App Store Smart Banner (iOS) -->
    <meta name="apple-itunes-app" content="app-id=YOUR_APP_ID" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <link rel="apple-touch-icon" href="/logo.svg" />

    <!-- Sitemap -->
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={jsonLd} />
  </head>
  <body class="bg-background-light dark:bg-background-dark text-slate-900 dark:text-slate-100 antialiased font-display">
    <slot />

    <script is:inline define:vars={{ lang }}>
      // Pass server-side props to client-side bundled scripts
      window._slaycal_lang = lang;
    </script>

    <script>
      import { initAnalytics, logAnalyticsEvent, AnalyticsEvents } from '../lib/analytics';

      async function setup() {
        // 1. Init Analytics (Browser only, safe for SSR)
        await initAnalytics();

        // 2. Log Page Context once per load
        const lang = (window as any)._slaycal_lang || document.documentElement.lang || 'en';
        logAnalyticsEvent(AnalyticsEvents.PAGE_CONTEXT, {
          lang,
          page_path: window.location.pathname,
          title: document.title
        });

        // 3. Setup Store Click Tracking (Delegated)
        // This catches clicks on links with data-analytics-store attribute
        document.addEventListener('click', (event) => {
          const target = event.target as HTMLElement;
          const storeLink = target.closest('[data-analytics-store]');
          
          if (storeLink) {
            const store = storeLink.getAttribute('data-analytics-store');
            const placement = storeLink.getAttribute('data-analytics-placement');
            const url = (storeLink as HTMLAnchorElement).href;

            logAnalyticsEvent(AnalyticsEvents.STORE_CLICK, {
              store,
              placement,
              link_url: url,
              lang
            });
          }
        });
      }

      // Initialize on load
      setup();
    </script>
  </body>
</html>
