---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const { features } = t;
---

<section class="bg-white/50 py-24 px-6 lg:px-20" id="features" aria-labelledby="features-title">
  <div class="mx-auto max-w-7xl">

    <!-- Section header -->
    <div class="mb-16 text-center max-w-2xl mx-auto">
      <span class="inline-block rounded-full bg-primary/10 px-4 py-1 text-xs font-bold uppercase tracking-widest text-primary mb-4">
        {features.section_label}
      </span>
      <h2 id="features-title" class="text-3xl font-bold tracking-tight lg:text-4xl">
        {features.title}
      </h2>
      <p class="mt-4 text-slate-600 text-lg">{features.subtitle}</p>
    </div>

    <!-- Features grid -->
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {features.items.map((feature) => (
        <div class="group flex flex-col gap-5 rounded-2xl border border-slate-100 bg-white p-7 transition-all duration-300 hover:shadow-xl hover:shadow-primary/5 hover:-translate-y-1">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary transition-transform duration-300 group-hover:scale-110 group-hover:bg-primary group-hover:text-white">
            <span class="material-symbols-outlined text-2xl">{feature.icon}</span>
          </div>
          <div class="space-y-2">
            <h3 class="text-base font-bold text-slate-900">{feature.title}</h3>
            <p class="text-sm text-slate-600 leading-relaxed">{feature.description}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Bottom trust bar -->
    <div class="mt-16 flex flex-wrap items-center justify-center gap-8 text-sm text-slate-400 border-t border-slate-100 pt-12">
      <div class="flex items-center gap-2">
        <span class="material-symbols-outlined text-primary text-lg">verified</span>
        <span>iOS & Android</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="material-symbols-outlined text-primary text-lg">lock</span>
        <span>{features.items[0].title.includes('AI') ? 'Privacy first' : 'Gizlilik öncelikli'}</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="material-symbols-outlined text-primary text-lg">bolt</span>
        <span>{features.items[0].icon === 'photo_camera' ? 'Real-time AI' : 'Gerçek zamanlı yapay zeka'}</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="material-symbols-outlined text-primary text-lg">star</span>
        <span>4.8 ★ rating</span>
      </div>
    </div>
  </div>
</section>
