---
// Features Section
const features = [
  {
    icon: 'cooking',
    title: 'Scan to Recipe',
    description: 'Take a photo of your fridge or pantry, and our AI instantly suggests chef-quality recipes based on what you have.',
  },
  {
    icon: 'photo_camera',
    title: 'Scan to Nutrition',
    description: 'Scan any meal to instantly calculate calories, macros, and vitamins. No more manual data entry.',
  },
  {
    icon: 'analytics',
    title: 'Track & Grow',
    description: 'Log meals and water intake with a single tap. Watch your progress through beautiful, intuitive analytics.',
  },
];
---

<section class="bg-white/50 py-24 px-6 lg:px-20" id="features">
  <div class="mx-auto max-w-7xl">
    <div class="mb-16 text-center">
      <h2 class="text-3xl font-bold tracking-tight lg:text-4xl">Smart tools for modern cooking</h2>
      <p class="mt-4 text-slate-600">Our AI understands your food as well as you do.</p>
    </div>

    <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
      {features.map((feature) => (
        <div class="group flex flex-col gap-6 rounded-lg border border-slate-100 bg-white p-8 transition-all hover:shadow-xl hover:shadow-primary/5">
          <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-primary/10 text-primary transition-transform group-hover:scale-110">
            <span class="material-symbols-outlined text-3xl">{feature.icon}</span>
          </div>
          <div class="space-y-2">
            <h3 class="text-xl font-bold">{feature.title}</h3>
            <p class="text-slate-600 leading-relaxed">{feature.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
