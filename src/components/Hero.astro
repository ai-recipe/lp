---
// Hero Section
const heroImageUrl = "https://lh3.googleusercontent.com/aida-public/AB6AXuCklNBEpr1TcG-Sno0kNXMpwo2TCJYT0ZmLsRpd4wKCIAhxEhvgw6-hrOuqbssTmuEKkKUVUCDGuG2Y4gCxA1F2JEbX8zC6Rv6P4PgwZfJ_IR8V8ws3jZDLPJj8iU7-Yp9OsYmCvt0nL6JRPB8g-Iy3VDwfHmy0zkWfqDLZlZrifJcsKFEp7STTEi0lSaBbsNmg2sI0woYVCq4Dq0oaK1rP7FRMpG4VWgcvw7QddSTf9hlSkwMYfQ_vDmsymsc4Wt27cIGWC2j6_-U";
---

<section class="relative overflow-hidden px-6 pt-16 pb-24 lg:px-20 lg:pt-32">
  <div class="blob-bg absolute -top-24 -left-24 h-96 w-96 rounded-full blur-3xl"></div>
  <div class="blob-bg absolute top-1/2 -right-24 h-96 w-96 rounded-full blur-3xl"></div>

  <div class="mx-auto max-w-7xl">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-center">
      <!-- Left: Text -->
      <div class="flex flex-col gap-8">
        <div class="space-y-4">
          <h1 class="text-5xl font-bold leading-tight tracking-tight lg:text-7xl">
            Create <span class="text-accent italic">Magic</span> in the Kitchen
          </h1>
          <p class="text-lg text-slate-600 lg:text-xl max-w-lg">
            Turn fridge ingredients into gourmet recipes with your AI chef. Professional cooking, simplified for your home.
          </p>
        </div>

        <!-- App Store Download Buttons -->
        <div class="flex flex-wrap gap-4">
          <!-- App Store -->
          <a
            href="#"
            class="flex items-center gap-3 px-6 py-3 rounded-2xl bg-slate-900 text-white hover:bg-slate-700 transition-all shadow-xl hover:translate-y-[-2px]"
            aria-label="Download on the App Store"
          >
            <svg class="w-7 h-7 fill-white shrink-0" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
            </svg>
            <div class="flex flex-col leading-tight">
              <span class="text-[10px] font-medium opacity-80">Download on the</span>
              <span class="text-base font-bold">App Store</span>
            </div>
          </a>

          <!-- Google Play -->
          <a
            href="#"
            class="flex items-center gap-3 px-6 py-3 rounded-2xl bg-primary text-white hover:bg-accent transition-all shadow-xl shadow-primary/30 hover:translate-y-[-2px]"
            aria-label="Get it on Google Play"
          >
            <svg class="w-7 h-7 fill-white shrink-0" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M3.18 23.76A2 2 0 0 1 2 22V2a2 2 0 0 1 1.18-1.76l11.65 11.76zm15.49-8.58L16.07 13.5 3.64.05l.88-.05 14.15 7.87a2 2 0 0 1 0 3.31zM3.64 23.95 16.07 10.5l2.6 1.55-14.15 7.87z"/>
            </svg>
            <div class="flex flex-col leading-tight">
              <span class="text-[10px] font-medium opacity-80">Get it on</span>
              <span class="text-base font-bold">Google Play</span>
            </div>
          </a>
        </div>

        <!-- Social proof -->
        <div class="flex items-center gap-4 text-sm text-slate-500">
          <div class="flex -space-x-2">
            <div class="h-8 w-8 rounded-full border-2 border-white bg-slate-200" aria-label="User avatar 1"></div>
            <div class="h-8 w-8 rounded-full border-2 border-white bg-slate-300" aria-label="User avatar 2"></div>
            <div class="h-8 w-8 rounded-full border-2 border-white bg-slate-400" aria-label="User avatar 3"></div>
          </div>
          <p>Joined by 10k+ home chefs this month</p>
        </div>
      </div>

      <!-- Right: Image -->
      <div class="relative">
        <div
          class="aspect-square w-full rounded-xl bg-slate-200 shadow-2xl overflow-hidden"
          style={`background-image: url("${heroImageUrl}"); background-size: cover; background-position: center;`}
          aria-label="Modern kitchen with fresh vegetables and tablet showing recipe"
        >
          <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
        </div>
        <div class="absolute -bottom-6 -left-6 rounded-lg bg-white p-6 shadow-xl lg:p-8">
          <div class="flex items-center gap-4">
            <div class="rounded-full bg-green-100 p-2 text-green-600">
              <span class="material-symbols-outlined">auto_awesome</span>
            </div>
            <div>
              <p class="text-sm font-bold">AI Suggested</p>
              <p class="text-xs text-slate-500">Lemon Garlic Salmon</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
