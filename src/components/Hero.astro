---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const { hero, nav } = t;

const heroImageUrl =
  "hero.png"
---

<section class="relative overflow-hidden px-6 pt-16 pb-24 lg:px-20 lg:pt-32" aria-label="Hero">
  <!-- Background blobs -->
  <div class="blob-bg absolute -top-24 -left-24 h-96 w-96 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>
  <div class="blob-bg absolute top-1/2 -right-24 h-96 w-96 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>

  <div class="mx-auto max-w-7xl">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-center">

      <!-- Left: Text -->
      <div class="flex flex-col gap-8">

        <div class="space-y-2">
          <h1 class="text-5xl font-bold leading-tight tracking-tight lg:text-6xl xl:text-7xl">
            {hero.title_1}{' '}
            <span class="text-primary italic">{hero.title_highlight}</span>
            <br />{hero.title_2}
          </h1>
          <p class="text-lg text-slate-600 lg:text-xl max-w-lg leading-relaxed mt-4">
            {hero.subtitle}
          </p>
        </div>

        <!-- App Store Download Buttons -->
        <div class="flex flex-wrap gap-4" role="group" aria-label="Download SlayCal">
          <!-- App Store -->
          <a
            href="#"
            class="flex items-center gap-3 px-6 py-3.5 rounded-2xl bg-slate-900 text-white hover:bg-slate-700 transition-all shadow-xl hover:-translate-y-0.5 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-slate-900"
            aria-label={`${nav.download_ios_sub} ${nav.store_ios}`}
            data-analytics-store="ios"
            data-analytics-placement="hero"
          >
            <svg class="w-7 h-7 fill-white shrink-0" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
            </svg>
            <div class="flex flex-col leading-tight">
              <span class="text-[10px] font-medium opacity-80">{nav.download_ios_sub}</span>
              <span class="text-base font-bold">{nav.store_ios}</span>
            </div>
          </a>

          <!-- Google Play -->
          <a
            href="https://play.google.com/store/apps/details?id=com.slaycal.android"
            class="flex items-center gap-3 px-6 py-3.5 rounded-2xl bg-primary text-white hover:bg-accent transition-all shadow-xl shadow-primary/30 hover:-translate-y-0.5 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
            aria-label={`${nav.download_android_sub} ${nav.store_android}`}
            data-analytics-store="android"
            data-analytics-placement="hero"
          >
            <svg class="w-7 h-7 fill-white shrink-0" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M3.18 23.76A2 2 0 0 1 2 22V2a2 2 0 0 1 1.18-1.76l11.65 11.76zm15.49-8.58L16.07 13.5 3.64.05l.88-.05 14.15 7.87a2 2 0 0 1 0 3.31zM3.64 23.95 16.07 10.5l2.6 1.55-14.15 7.87z"/>
            </svg>
            <div class="flex flex-col leading-tight">
              <span class="text-[10px] font-medium opacity-80">{nav.download_android_sub}</span>
              <span class="text-base font-bold">{nav.store_android}</span>
            </div>
          </a>
        </div>

 
      </div>

      <!-- Right: App Preview -->
      <div class="relative" aria-hidden="true">
        <div
          class="aspect-[4/5] w-full rounded-2xl bg-slate-200 shadow-2xl overflow-hidden"
          style={`background-image: url("${heroImageUrl}"); background-size: cover; background-position: center;`}
          role="img"
          aria-label="SlayCal app showing AI meal recognition and nutrition data"
        >
          <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent rounded-2xl"></div>
        </div>

        <!-- Floating AI suggestion card -->
        <div class="absolute -bottom-6 -left-6 rounded-xl bg-white p-4 shadow-2xl shadow-slate-200 border border-slate-100 max-w-[200px]">
          <div class="flex items-center gap-3">
            <div class="rounded-full bg-green-100 p-2 text-green-600 shrink-0">
              <span class="material-symbols-outlined text-xl">auto_awesome</span>
            </div>
            <div>
              <p class="text-xs font-bold text-slate-900">{hero.ai_suggested}</p>
              <p class="text-xs text-slate-500">{hero.ai_recipe}</p>
            </div>
          </div>
        </div>

        <!-- Floating nutrition card -->
        <div class="absolute -top-4 -right-4 rounded-xl bg-white p-3 shadow-2xl shadow-slate-200 border border-slate-100">
          <p class="text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-2">Nutrition</p>
          <div class="space-y-1.5">
            <div class="flex items-center gap-2">
              <div class="h-1.5 w-1.5 rounded-full bg-chart-protein shrink-0"></div>
              <div class="h-1.5 flex-1 rounded-full bg-slate-100 overflow-hidden">
                <div class="h-full bg-chart-protein rounded-full" style="width: 68%"></div>
              </div>
              <span class="text-[10px] font-medium text-slate-600">68%</span>
            </div>
            <div class="flex items-center gap-2">
              <div class="h-1.5 w-1.5 rounded-full bg-chart-carbs shrink-0"></div>
              <div class="h-1.5 flex-1 rounded-full bg-slate-100 overflow-hidden">
                <div class="h-full bg-chart-carbs rounded-full" style="width: 82%"></div>
              </div>
              <span class="text-[10px] font-medium text-slate-600">82%</span>
            </div>
            <div class="flex items-center gap-2">
              <div class="h-1.5 w-1.5 rounded-full bg-chart-fat shrink-0"></div>
              <div class="h-1.5 flex-1 rounded-full bg-slate-100 overflow-hidden">
                <div class="h-full bg-chart-fat rounded-full" style="width: 45%"></div>
              </div>
              <span class="text-[10px] font-medium text-slate-600">45%</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
