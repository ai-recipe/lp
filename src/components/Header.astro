---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations;
  lang?: string;
  currentPath?: string;
}

const { t, lang = 'en', currentPath = '/' } = Astro.props;
const { nav } = t;
const logoHref = lang === 'en' ? '/' : `/${lang}/`;
const base = lang === 'en' ? '' : `/${lang}`;

const navLabels: Record<string, { home: string; calculators: string; blog: string; privacy: string; terms: string }> = {
  en: { home: 'Home', calculators: 'Calculators', blog: 'Blog', privacy: 'Privacy', terms: 'Terms' },
  tr: { home: 'Ana Sayfa', calculators: 'Hesaplayıcılar', blog: 'Blog', privacy: 'Gizlilik', terms: 'Şartlar' },
  es: { home: 'Inicio', calculators: 'Calculadoras', blog: 'Blog', privacy: 'Privacidad', terms: 'Términos' },
  fr: { home: 'Accueil', calculators: 'Calculatrices', blog: 'Blog', privacy: 'Confidentialité', terms: 'Conditions' },
  de: { home: 'Startseite', calculators: 'Rechner', blog: 'Blog', privacy: 'Datenschutz', terms: 'AGB' },
  'pt-br': { home: 'Início', calculators: 'Calculadoras', blog: 'Blog', privacy: 'Privacidade', terms: 'Termos' },
  ru: { home: 'Главная', calculators: 'Калькуляторы', blog: 'Блог', privacy: 'Конфиденциальность', terms: 'Условия' },
  ja: { home: 'ホーム', calculators: '計算機', blog: 'ブログ', privacy: 'プライバシー', terms: '利用規約' },
  ko: { home: '홈', calculators: '계산기', blog: '블로그', privacy: '개인정보', terms: '약관' },
  it: { home: 'Home', calculators: 'Calcolatrici', blog: 'Blog', privacy: 'Privacy', terms: 'Termini' },
};
const labels = navLabels[lang] ?? navLabels.en;

const mainNav = [
  { label: labels.home, href: logoHref },
  { label: labels.calculators, href: `${base}/calculators` },
  { label: labels.blog, href: `${base}/blog` },
  { label: labels.privacy, href: `${base}/privacy` },
  { label: labels.terms, href: `${base}/terms` },
];

const calculatorPaths = new Set([
  '/calculators',
  '/bmi-calculator',
  '/calorie-calculator',
  '/macro-calculator',
  '/body-fat-calculator',
]);
const pathAvailability: Record<string, Set<string>> = {
  tr: new Set([...calculatorPaths, '/terms']),
};

function resolveLangHref(code: string, path: string): string {
  if (code === 'en') return path;
  if (path === '/' || path === '') return `/${code}/`;
  const available = pathAvailability[code];
  if (available && available.has(path)) return `/${code}${path}`;
  return `/${code}/`;
}
---

<header class="sticky top-0 z-50 w-full border-b border-primary/10 bg-background-light/80 backdrop-blur-md" id="site-header">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-3 lg:px-20">

    <!-- Logo -->
    <a href={logoHref} class="flex items-center gap-2 shrink-0" aria-label="SlayCal – Home">
      <img src="/logo.svg" alt="SlayCal" class="h-16" />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-6" aria-label="Main navigation">
      {mainNav.map(({ label, href }) => (
        <a
          class={`text-sm font-medium transition-colors ${currentPath === href ? 'text-primary' : 'text-slate-600 hover:text-primary'}`}
          href={href}
        >
          {label}
        </a>
      ))}
    </nav>

    <!-- Desktop CTA buttons -->
    <div class="hidden md:flex items-center gap-3">
      <a
        href="#"
        class="flex items-center gap-2 px-4 py-2 rounded-full border border-slate-800 bg-slate-900 text-white text-xs font-semibold hover:bg-slate-700 transition-all"
        aria-label={`${nav.download_ios_sub} ${nav.store_ios}`}
        data-analytics-store="ios"
        data-analytics-placement="header"
      >
        <svg class="w-4 h-4 fill-white shrink-0" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
        </svg>
        <span>{nav.store_ios}</span>
      </a>
      <a
        href="https://play.google.com/store/apps/details?id=com.slaycal.android"
        class="flex items-center gap-2 px-4 py-2 rounded-full bg-primary text-white text-xs font-semibold shadow-lg shadow-primary/20 hover:scale-105 transition-all"
        aria-label={`${nav.download_android_sub} ${nav.store_android}`}
        data-analytics-store="android"
        data-analytics-placement="header"
      >
        <svg class="w-4 h-4 fill-white shrink-0" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M3.18 23.76A2 2 0 0 1 2 22V2a2 2 0 0 1 1.18-1.76l11.65 11.76zm15.49-8.58L16.07 13.5 3.64.05l.88-.05 14.15 7.87a2 2 0 0 1 0 3.31zM3.64 23.95 16.07 10.5l2.6 1.55-14.15 7.87z"/>
        </svg>
        <span>{nav.store_android}</span>
      </a>
    </div>

    <!-- Mobile: hamburger button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden flex items-center justify-center w-10 h-10 rounded-xl text-slate-700 hover:bg-slate-100 transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-primary"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <!-- Hamburger icon (3 lines) -->
      <span id="hamburger-icon" class="flex flex-col justify-center items-center gap-1.5 w-5" aria-hidden="true">
        <span class="ham-line block h-0.5 w-5 bg-slate-700 rounded-full transition-all duration-300 origin-center"></span>
        <span class="ham-line block h-0.5 w-5 bg-slate-700 rounded-full transition-all duration-300"></span>
        <span class="ham-line block h-0.5 w-5 bg-slate-700 rounded-full transition-all duration-300 origin-center"></span>
      </span>
    </button>

  </div>
</header>

<!-- Mobile menu overlay -->
<div
  id="mobile-menu-backdrop"
  class="fixed inset-0 z-40 bg-slate-900/40 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300 md:hidden"
  aria-hidden="true"
></div>

<!-- Mobile menu drawer -->
<div
  id="mobile-menu"
  role="dialog"
  aria-modal="true"
  aria-label="Navigation menu"
  class="fixed top-0 right-0 z-50 h-full w-[min(320px,90vw)] bg-white shadow-2xl translate-x-full transition-transform duration-300 ease-in-out md:hidden flex flex-col"
>
  <!-- Drawer header -->
  <div class="flex items-center justify-between px-6 py-4 border-b border-slate-100">
    <a href={logoHref} class="flex items-center gap-2" aria-label="SlayCal – Home">
      <img src="/logo.svg" alt="SlayCal" class="h-12" />
    </a>
    <button
      id="mobile-menu-close"
      class="flex items-center justify-center w-9 h-9 rounded-xl text-slate-600 hover:bg-slate-100 transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-primary"
      aria-label="Close menu"
    >
      <span class="material-symbols-outlined text-xl">close</span>
    </button>
  </div>

  <!-- Nav links -->
  <nav class="flex-1 overflow-y-auto px-4 py-6 space-y-1" aria-label="Mobile navigation">
    {mainNav.map(({ label, href }) => (
      <a
        href={href}
        class={`flex items-center gap-3 px-4 py-3 rounded-2xl text-sm font-semibold transition-all ${currentPath === href ? 'bg-primary/10 text-primary' : 'text-slate-700 hover:bg-slate-50 hover:text-primary'}`}
      >
        {label}
        {currentPath === href && <span class="ml-auto w-1.5 h-1.5 rounded-full bg-primary"></span>}
      </a>
    ))}
  </nav>

  <!-- App store CTAs at the bottom -->
  <div class="px-4 pb-8 pt-4 border-t border-slate-100 space-y-3">
    <p class="text-xs font-bold uppercase tracking-wider text-slate-400 px-2 mb-3">Download the app</p>
    <a
      href="#"
      class="flex items-center gap-3 px-4 py-3.5 rounded-2xl bg-slate-900 text-white hover:bg-slate-800 transition-all focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-slate-900"
      data-analytics-store="ios"
      data-analytics-placement="mobile_menu"
    >
      <svg class="w-5 h-5 fill-white shrink-0" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
      </svg>
      <div class="flex flex-col leading-none">
        <span class="text-[9px] opacity-70 mb-0.5">{nav.download_ios_sub}</span>
        <span class="text-sm font-bold">{nav.store_ios}</span>
      </div>
    </a>
    <a
      href="https://play.google.com/store/apps/details?id=com.slaycal.android"
      class="flex items-center gap-3 px-4 py-3.5 rounded-2xl bg-primary text-white hover:bg-accent transition-all focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
      data-analytics-store="android"
      data-analytics-placement="mobile_menu"
    >
      <svg class="w-5 h-5 fill-white shrink-0" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M3.18 23.76A2 2 0 0 1 2 22V2a2 2 0 0 1 1.18-1.76l11.65 11.76zm15.49-8.58L16.07 13.5 3.64.05l.88-.05 14.15 7.87a2 2 0 0 1 0 3.31zM3.64 23.95 16.07 10.5l2.6 1.55-14.15 7.87z"/>
      </svg>
      <div class="flex flex-col leading-none">
        <span class="text-[9px] opacity-70 mb-0.5">{nav.download_android_sub}</span>
        <span class="text-sm font-bold">{nav.store_android}</span>
      </div>
    </a>
  </div>
</div>

<script>
  const btn = document.getElementById('mobile-menu-btn')!;
  const closeBtn = document.getElementById('mobile-menu-close')!;
  const menu = document.getElementById('mobile-menu')!;
  const backdrop = document.getElementById('mobile-menu-backdrop')!;
  const lines = document.querySelectorAll<HTMLElement>('.ham-line');

  function openMenu() {
    menu.classList.remove('translate-x-full');
    backdrop.classList.remove('opacity-0', 'pointer-events-none');
    backdrop.classList.add('opacity-100');
    btn.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';

    // Animate to X
    lines[0].style.transform = 'translateY(8px) rotate(45deg)';
    lines[1].style.opacity = '0';
    lines[2].style.transform = 'translateY(-8px) rotate(-45deg)';
  }

  function closeMenu() {
    menu.classList.add('translate-x-full');
    backdrop.classList.add('opacity-0', 'pointer-events-none');
    backdrop.classList.remove('opacity-100');
    btn.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';

    // Animate back to hamburger
    lines[0].style.transform = '';
    lines[1].style.opacity = '';
    lines[2].style.transform = '';
  }

  btn.addEventListener('click', () => {
    const isOpen = btn.getAttribute('aria-expanded') === 'true';
    isOpen ? closeMenu() : openMenu();
  });

  closeBtn.addEventListener('click', closeMenu);
  backdrop.addEventListener('click', closeMenu);

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && btn.getAttribute('aria-expanded') === 'true') {
      closeMenu();
      btn.focus();
    }
  });
</script>
