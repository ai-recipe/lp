---
// Shared Macro calculator content — used by EN and TR pages (calculator math is language-agnostic)
---

<main id="main-content">

  <!-- ── HERO ─────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden bg-background-light px-6 pt-20 pb-10 lg:px-20 lg:pt-28 lg:pb-12">
    <div class="blob-bg absolute -top-40 left-1/2 -translate-x-1/2 w-[600px] h-[600px] opacity-40 pointer-events-none" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-4xl">
      <nav class="flex items-center gap-2 text-xs text-slate-400 mb-6" aria-label="Breadcrumb">
        <a href="/" class="hover:text-primary transition-colors">SlayCal</a>
        <span class="material-symbols-outlined text-sm">chevron_right</span>
        <a href="/calculators" class="hover:text-primary transition-colors">Calculators</a>
        <span class="material-symbols-outlined text-sm">chevron_right</span>
        <span class="text-slate-600 font-medium">Macro Calculator</span>
      </nav>
      <div class="inline-flex items-center gap-2 rounded-full bg-emerald-50 px-4 py-1.5 mb-5">
        <span class="material-symbols-outlined text-emerald-500 text-base leading-none">pie_chart</span>
        <span class="text-sm font-semibold text-emerald-600">Free · Instant split</span>
      </div>
      <h1 class="text-4xl font-bold text-slate-900 lg:text-5xl leading-tight tracking-tight">Macro Calculator</h1>
      <p class="mt-4 text-lg text-slate-500 max-w-xl leading-relaxed">Split your daily calories into protein, carbs, and fat — tuned to your goal and diet preference.</p>
    </div>
  </section>

  <!-- ── CALCULATOR ─────────────────────────────────────────────── -->
  <section class="bg-background-light px-6 pb-16 lg:px-20" aria-label="Macro Calculator">
    <div class="mx-auto max-w-4xl">
      <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">

        <div class="rounded-3xl bg-white border border-slate-100 shadow-sm p-8">
          <h2 class="text-lg font-bold text-slate-900 mb-6">Your numbers</h2>

          <div class="flex rounded-xl bg-background-light p-1 mb-6 w-fit" role="group" aria-label="Unit system">
            <button id="unit-metric" class="unit-btn px-5 py-2 rounded-lg text-sm font-semibold bg-white text-slate-900 shadow-sm transition-all" aria-pressed="true">Metric</button>
            <button id="unit-imperial" class="unit-btn px-5 py-2 rounded-lg text-sm font-semibold text-slate-500 hover:text-slate-700 transition-all" aria-pressed="false">Imperial</button>
          </div>

          <form id="macro-form" novalidate>
            <div class="mb-5">
              <label class="block text-sm font-semibold text-slate-700 mb-2">Sex</label>
              <div class="grid grid-cols-2 gap-3">
                <label class="flex items-center justify-center gap-2 py-3 px-4 rounded-xl border border-slate-200 bg-background-light cursor-pointer has-[:checked]:border-emerald-500 has-[:checked]:bg-emerald-50 has-[:checked]:text-emerald-600 transition-all">
                  <input type="radio" name="sex" value="male" checked class="sr-only" />
                  <span class="material-symbols-outlined text-base">male</span>
                  <span class="text-sm font-semibold">Male</span>
                </label>
                <label class="flex items-center justify-center gap-2 py-3 px-4 rounded-xl border border-slate-200 bg-background-light cursor-pointer has-[:checked]:border-emerald-500 has-[:checked]:bg-emerald-50 has-[:checked]:text-emerald-600 transition-all">
                  <input type="radio" name="sex" value="female" class="sr-only" />
                  <span class="material-symbols-outlined text-base">female</span>
                  <span class="text-sm font-semibold">Female</span>
                </label>
              </div>
            </div>

            <div class="mb-5">
              <label for="age" class="block text-sm font-semibold text-slate-700 mb-2">Age</label>
              <div class="relative">
                <input type="number" id="age" min="10" max="120" placeholder="30" class="w-full rounded-xl border border-slate-200 bg-background-light px-4 py-3.5 pr-16 text-slate-900 placeholder-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20 transition-all" />
                <span class="absolute right-4 top-1/2 -translate-y-1/2 text-sm font-semibold text-slate-400">years</span>
              </div>
            </div>

            <div id="height-metric" class="mb-5">
              <label for="height-cm" class="block text-sm font-semibold text-slate-700 mb-2">Height</label>
              <div class="relative">
                <input type="number" id="height-cm" min="50" max="300" placeholder="175" class="w-full rounded-xl border border-slate-200 bg-background-light px-4 py-3.5 pr-14 text-slate-900 placeholder-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20 transition-all" />
                <span class="absolute right-4 top-1/2 -translate-y-1/2 text-sm font-semibold text-slate-400">cm</span>
              </div>
            </div>
            <div id="height-imperial" class="mb-5 hidden">
              <label class="block text-sm font-semibold text-slate-700 mb-2">Height</label>
              <div class="flex gap-3">
                <div class="relative flex-1">
                  <input type="number" id="height-ft" min="1" max="9" placeholder="5" class="w-full rounded-xl border border-slate-200 bg-background-light px-4 py-3.5 pr-12 text-slate-900 placeholder-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20 transition-all" />
                  <span class="absolute right-4 top-1/2 -translate-y-1/2 text-sm font-semibold text-slate-400">ft</span>
                </div>
                <div class="relative flex-1">
                  <input type="number" id="height-in" min="0" max="11" placeholder="9" class="w-full rounded-xl border border-slate-200 bg-background-light px-4 py-3.5 pr-12 text-slate-900 placeholder-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20 transition-all" />
                  <span class="absolute right-4 top-1/2 -translate-y-1/2 text-sm font-semibold text-slate-400">in</span>
                </div>
              </div>
            </div>

            <div id="weight-metric" class="mb-5">
              <label for="weight-kg" class="block text-sm font-semibold text-slate-700 mb-2">Weight</label>
              <div class="relative">
                <input type="number" id="weight-kg" min="10" max="500" placeholder="70" class="w-full rounded-xl border border-slate-200 bg-background-light px-4 py-3.5 pr-12 text-slate-900 placeholder-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20 transition-all" />
                <span class="absolute right-4 top-1/2 -translate-y-1/2 text-sm font-semibold text-slate-400">kg</span>
              </div>
            </div>
            <div id="weight-imperial" class="mb-5 hidden">
              <label for="weight-lbs" class="block text-sm font-semibold text-slate-700 mb-2">Weight</label>
              <div class="relative">
                <input type="number" id="weight-lbs" min="20" max="1100" placeholder="154" class="w-full rounded-xl border border-slate-200 bg-background-light px-4 py-3.5 pr-14 text-slate-900 placeholder-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20 transition-all" />
                <span class="absolute right-4 top-1/2 -translate-y-1/2 text-sm font-semibold text-slate-400">lbs</span>
              </div>
            </div>

            <div class="mb-5">
              <label for="activity" class="block text-sm font-semibold text-slate-700 mb-2">Activity level</label>
              <select id="activity" class="w-full rounded-xl border border-slate-200 bg-background-light px-4 py-3.5 text-slate-900 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20 transition-all">
                <option value="1.2">Sedentary</option>
                <option value="1.375">Lightly active</option>
                <option value="1.55" selected>Moderately active</option>
                <option value="1.725">Very active</option>
                <option value="1.9">Extra active</option>
              </select>
            </div>

            <div class="mb-5">
              <label for="goal" class="block text-sm font-semibold text-slate-700 mb-2">Goal</label>
              <select id="goal" class="w-full rounded-xl border border-slate-200 bg-background-light px-4 py-3.5 text-slate-900 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20 transition-all">
                <option value="-500">Fat loss (–500 kcal)</option>
                <option value="0" selected>Maintain weight</option>
                <option value="300">Muscle gain (+300 kcal)</option>
              </select>
            </div>

            <div class="mb-6">
              <label for="diet" class="block text-sm font-semibold text-slate-700 mb-2">Diet preference</label>
              <select id="diet" class="w-full rounded-xl border border-slate-200 bg-background-light px-4 py-3.5 text-slate-900 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20 transition-all">
                <option value="balanced" selected>Balanced (30 / 40 / 30)</option>
                <option value="high-protein">High-protein (40 / 35 / 25)</option>
                <option value="low-carb">Low-carb (35 / 25 / 40)</option>
                <option value="keto">Keto (25 / 5 / 70)</option>
              </select>
            </div>

            <button type="submit" class="w-full py-4 rounded-xl bg-emerald-500 text-white font-bold text-base hover:bg-emerald-600 transition-all shadow-lg shadow-emerald-500/25 hover:-translate-y-0.5">Calculate my macros</button>
          </form>
        </div>

        <div class="rounded-3xl border border-slate-100 bg-white shadow-sm p-8 flex flex-col" aria-live="polite">
          <div id="results-placeholder" class="flex flex-col items-center justify-center h-full min-h-48 text-center">
            <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-slate-50 mb-4">
              <span class="material-symbols-outlined text-slate-300 text-3xl">pie_chart</span>
            </div>
            <p class="text-sm text-slate-400 max-w-xs">Fill in your details to see your personalized macro split.</p>
          </div>
          <div id="results-content" class="hidden">
            <div class="flex items-center justify-between mb-2">
              <h2 class="text-lg font-bold text-slate-900">Your daily macros</h2>
              <button id="reset-btn" class="text-xs text-slate-400 hover:text-emerald-500 transition-colors flex items-center gap-1">
                <span class="material-symbols-outlined text-sm">refresh</span> Reset
              </button>
            </div>
            <div class="text-center my-6">
              <div id="target-value" class="text-5xl font-bold text-slate-900 tabular-nums">—</div>
              <div class="mt-1 text-sm font-semibold text-slate-500">kcal / day</div>
            </div>

            <div class="space-y-3 mb-6">
              <div class="rounded-2xl border border-blue-100 bg-blue-50 p-4">
                <div class="flex items-center justify-between mb-2">
                  <div class="flex items-center gap-2">
                    <span class="h-3 w-3 rounded-full bg-blue-500"></span>
                    <p class="text-sm font-semibold text-slate-800">Protein</p>
                  </div>
                  <p class="text-sm font-bold text-blue-600"><span id="protein-pct">—</span>%</p>
                </div>
                <p class="text-2xl font-bold text-slate-900 tabular-nums"><span id="protein-g">—</span> g</p>
                <p class="text-xs text-slate-500 mt-0.5"><span id="protein-kcal">—</span> kcal</p>
              </div>
              <div class="rounded-2xl border border-amber-100 bg-amber-50 p-4">
                <div class="flex items-center justify-between mb-2">
                  <div class="flex items-center gap-2">
                    <span class="h-3 w-3 rounded-full bg-amber-500"></span>
                    <p class="text-sm font-semibold text-slate-800">Carbs</p>
                  </div>
                  <p class="text-sm font-bold text-amber-600"><span id="carbs-pct">—</span>%</p>
                </div>
                <p class="text-2xl font-bold text-slate-900 tabular-nums"><span id="carbs-g">—</span> g</p>
                <p class="text-xs text-slate-500 mt-0.5"><span id="carbs-kcal">—</span> kcal</p>
              </div>
              <div class="rounded-2xl border border-rose-100 bg-rose-50 p-4">
                <div class="flex items-center justify-between mb-2">
                  <div class="flex items-center gap-2">
                    <span class="h-3 w-3 rounded-full bg-rose-500"></span>
                    <p class="text-sm font-semibold text-slate-800">Fat</p>
                  </div>
                  <p class="text-sm font-bold text-rose-600"><span id="fat-pct">—</span>%</p>
                </div>
                <p class="text-2xl font-bold text-slate-900 tabular-nums"><span id="fat-g">—</span> g</p>
                <p class="text-xs text-slate-500 mt-0.5"><span id="fat-kcal">—</span> kcal</p>
              </div>
            </div>

            <a href="#" class="flex items-center justify-center gap-2 w-full py-3.5 rounded-xl bg-slate-900 text-white font-bold text-sm hover:bg-slate-700 transition-all" data-analytics-store="ios" data-analytics-placement="macro_result">
              <span class="material-symbols-outlined text-base">photo_camera</span>Hit these macros effortlessly in SlayCal
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── WHAT MACROS DO ────────────────────────────────────────── -->
  <section class="bg-white px-6 py-16 lg:px-20" aria-labelledby="macros-title">
    <div class="mx-auto max-w-4xl">
      <h2 id="macros-title" class="text-2xl font-bold text-slate-900 mb-2">What each macro does</h2>
      <p class="text-slate-500 mb-8">The three macronutrients each play a specific role.</p>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
        {[
          { label: 'Protein', kcal: '4 kcal/g', desc: 'Builds and repairs muscle. Keeps you full. Essential for fat loss without losing lean mass.', color: 'bg-blue-50 border-blue-100 text-blue-700' },
          { label: 'Carbs', kcal: '4 kcal/g', desc: 'Primary fuel for your brain and training. Higher needs = higher training intensity.', color: 'bg-amber-50 border-amber-100 text-amber-700' },
          { label: 'Fat', kcal: '9 kcal/g', desc: 'Supports hormones and nutrient absorption. Don\'t cut below 20% of calories.', color: 'bg-rose-50 border-rose-100 text-rose-700' },
        ].map(({ label, kcal, desc, color }) => (
          <div class={`rounded-2xl border p-5 ${color}`}>
            <p class="text-xs font-bold uppercase tracking-wider mb-2">{kcal}</p>
            <p class="font-bold text-slate-900 text-base mb-2">{label}</p>
            <p class="text-xs text-slate-600 leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
      <div class="mt-8 rounded-2xl bg-amber-50 border border-amber-100 p-5 flex gap-3">
        <span class="material-symbols-outlined text-amber-500 text-xl shrink-0 mt-0.5">info</span>
        <p class="text-sm text-slate-600 leading-relaxed"><strong class="text-slate-800">Protein targets matter most.</strong> Aim for ~1.6–2.2 g/kg of body weight if you train. Carbs and fat can shift based on preference — both fuel you just fine.</p>
      </div>
    </div>
  </section>

  <!-- ── SLAYCAL CTA ────────────────────────────────────────────── -->
  <section class="relative overflow-hidden bg-gradient-to-br from-emerald-500 via-teal-500 to-cyan-500 px-6 py-20 lg:px-20" aria-labelledby="cta-macro-title">
    <div class="relative mx-auto max-w-3xl text-center">
      <h2 id="cta-macro-title" class="text-3xl font-bold text-white lg:text-4xl leading-tight">Targets mean nothing if you can't hit them.</h2>
      <p class="mt-4 text-white/80 max-w-xl mx-auto leading-relaxed">SlayCal snaps every meal and updates your protein, carb, and fat totals in real time — so hitting macros becomes automatic.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="#" class="flex items-center gap-2 px-7 py-3.5 rounded-2xl bg-white text-slate-900 font-bold hover:bg-slate-50 transition-all shadow-xl" data-analytics-store="ios" data-analytics-placement="macro_cta">
          <svg class="w-5 h-5 fill-slate-900 shrink-0" viewBox="0 0 24 24"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
          Download free on iOS
        </a>
        <a href="#" class="flex items-center gap-2 px-7 py-3.5 rounded-2xl bg-white/15 border-2 border-white/30 text-white font-bold hover:bg-white/25 transition-all" data-analytics-store="android" data-analytics-placement="macro_cta">
          <svg class="w-5 h-5 fill-white shrink-0" viewBox="0 0 24 24"><path d="M3.18 23.76A2 2 0 0 1 2 22V2a2 2 0 0 1 1.18-1.76l11.65 11.76zm15.49-8.58L16.07 13.5 3.64.05l.88-.05 14.15 7.87a2 2 0 0 1 0 3.31zM3.64 23.95 16.07 10.5l2.6 1.55-14.15 7.87z"/></svg>
          Get it on Google Play
        </a>
      </div>
      <p class="mt-5 text-xs text-white/60">Free · 500 scan credits · No credit card</p>
    </div>
  </section>

  <!-- ── OTHER CALCULATORS ──────────────────────────────────────── -->
  <section class="bg-white px-6 py-16 lg:px-20" aria-labelledby="more-macro-title">
    <div class="mx-auto max-w-4xl">
      <h2 id="more-macro-title" class="text-xl font-bold text-slate-900 mb-6">More free calculators</h2>
      <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
        {[
          { href: '/bmi-calculator', icon: 'monitor_weight', label: 'BMI Calculator', desc: 'Check if your weight is in a healthy range.' },
          { href: '/calorie-calculator', icon: 'local_fire_department', label: 'Calorie Calculator', desc: 'Find your daily calorie target.' },
          { href: '/body-fat-calculator', icon: 'straighten', label: 'Body Fat Calculator', desc: 'Estimate your body fat percentage.' },
        ].map(({ href, icon, label, desc }) => (
          <a href={href} class="flex items-center gap-4 p-4 rounded-2xl border border-slate-100 hover:border-emerald-200 hover:bg-emerald-50/50 transition-all group">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-emerald-100">
              <span class="material-symbols-outlined text-emerald-600 text-xl">{icon}</span>
            </div>
            <div>
              <p class="text-sm font-semibold text-slate-800 group-hover:text-emerald-600 transition-colors">{label}</p>
              <p class="text-xs text-slate-400">{desc}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</main>

<script>
  const metricBtn = document.getElementById('unit-metric')!;
  const imperialBtn = document.getElementById('unit-imperial')!;
  const form = document.getElementById('macro-form')!;
  const placeholder = document.getElementById('results-placeholder')!;
  const resultsContent = document.getElementById('results-content')!;
  const resetBtn = document.getElementById('reset-btn')!;
  let isMetric = true;

  function setUnit(metric: boolean) {
    isMetric = metric;
    metricBtn.setAttribute('aria-pressed', String(metric));
    imperialBtn.setAttribute('aria-pressed', String(!metric));
    const active = ['bg-white', 'text-slate-900', 'shadow-sm'];
    if (metric) {
      metricBtn.classList.add(...active); metricBtn.classList.remove('text-slate-500');
      imperialBtn.classList.remove(...active); imperialBtn.classList.add('text-slate-500');
    } else {
      imperialBtn.classList.add(...active); imperialBtn.classList.remove('text-slate-500');
      metricBtn.classList.remove(...active); metricBtn.classList.add('text-slate-500');
    }
    document.getElementById('height-metric')!.classList.toggle('hidden', !metric);
    document.getElementById('height-imperial')!.classList.toggle('hidden', metric);
    document.getElementById('weight-metric')!.classList.toggle('hidden', !metric);
    document.getElementById('weight-imperial')!.classList.toggle('hidden', metric);
  }

  metricBtn.addEventListener('click', () => setUnit(true));
  imperialBtn.addEventListener('click', () => setUnit(false));

  const dietSplits: Record<string, { p: number; c: number; f: number }> = {
    'balanced':     { p: 0.30, c: 0.40, f: 0.30 },
    'high-protein': { p: 0.40, c: 0.35, f: 0.25 },
    'low-carb':     { p: 0.35, c: 0.25, f: 0.40 },
    'keto':         { p: 0.25, c: 0.05, f: 0.70 },
  };

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const sexInput = document.querySelector('input[name="sex"]:checked') as HTMLInputElement | null;
    const sex = sexInput?.value === 'female' ? 'female' : 'male';
    const age = parseFloat((document.getElementById('age') as HTMLInputElement).value);
    const activity = parseFloat((document.getElementById('activity') as HTMLSelectElement).value);
    const goalAdj = parseFloat((document.getElementById('goal') as HTMLSelectElement).value);
    const dietKey = (document.getElementById('diet') as HTMLSelectElement).value;

    let heightCm: number, weightKg: number;
    if (isMetric) {
      heightCm = parseFloat((document.getElementById('height-cm') as HTMLInputElement).value);
      weightKg = parseFloat((document.getElementById('weight-kg') as HTMLInputElement).value);
      if (!heightCm || !weightKg) return;
    } else {
      const ft = parseFloat((document.getElementById('height-ft') as HTMLInputElement).value) || 0;
      const inches = parseFloat((document.getElementById('height-in') as HTMLInputElement).value) || 0;
      const lbs = parseFloat((document.getElementById('weight-lbs') as HTMLInputElement).value);
      if ((!ft && !inches) || !lbs) return;
      heightCm = ((ft * 12) + inches) * 2.54;
      weightKg = lbs * 0.453592;
    }
    if (!age) return;

    const bmr = sex === 'male'
      ? 10 * weightKg + 6.25 * heightCm - 5 * age + 5
      : 10 * weightKg + 6.25 * heightCm - 5 * age - 161;
    const tdee = bmr * activity;
    const target = Math.max(1000, tdee + goalAdj);

    const split = dietSplits[dietKey] ?? dietSplits.balanced;
    const proteinKcal = target * split.p;
    const carbsKcal = target * split.c;
    const fatKcal = target * split.f;
    const proteinG = Math.round(proteinKcal / 4);
    const carbsG = Math.round(carbsKcal / 4);
    const fatG = Math.round(fatKcal / 9);

    document.getElementById('target-value')!.textContent = String(Math.round(target));
    document.getElementById('protein-pct')!.textContent = String(Math.round(split.p * 100));
    document.getElementById('carbs-pct')!.textContent = String(Math.round(split.c * 100));
    document.getElementById('fat-pct')!.textContent = String(Math.round(split.f * 100));
    document.getElementById('protein-g')!.textContent = String(proteinG);
    document.getElementById('carbs-g')!.textContent = String(carbsG);
    document.getElementById('fat-g')!.textContent = String(fatG);
    document.getElementById('protein-kcal')!.textContent = String(Math.round(proteinKcal));
    document.getElementById('carbs-kcal')!.textContent = String(Math.round(carbsKcal));
    document.getElementById('fat-kcal')!.textContent = String(Math.round(fatKcal));

    placeholder.classList.add('hidden');
    resultsContent.classList.remove('hidden');
  });

  resetBtn.addEventListener('click', () => {
    resultsContent.classList.add('hidden');
    placeholder.classList.remove('hidden');
    (form as HTMLFormElement).reset();
  });
</script>
