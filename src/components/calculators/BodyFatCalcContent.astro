---
// Shared Body Fat calculator content — used by EN and TR pages (calculator math is language-agnostic)
---

<main id="main-content">

  <!-- ── HERO ─────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden bg-background-light px-6 pt-20 pb-10 lg:px-20 lg:pt-28 lg:pb-12">
    <div class="blob-bg absolute -top-40 left-1/2 -translate-x-1/2 w-[600px] h-[600px] opacity-40 pointer-events-none" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-4xl">
      <nav class="flex items-center gap-2 text-xs text-slate-400 mb-6" aria-label="Breadcrumb">
        <a href="/" class="hover:text-primary transition-colors">SlayCal</a>
        <span class="material-symbols-outlined text-sm">chevron_right</span>
        <a href="/calculators" class="hover:text-primary transition-colors">Calculators</a>
        <span class="material-symbols-outlined text-sm">chevron_right</span>
        <span class="text-slate-600 font-medium">Body Fat Calculator</span>
      </nav>
      <div class="inline-flex items-center gap-2 rounded-full bg-violet-50 px-4 py-1.5 mb-5">
        <span class="material-symbols-outlined text-violet-500 text-base leading-none">straighten</span>
        <span class="text-sm font-semibold text-violet-600">Free · US Navy method</span>
      </div>
      <h1 class="text-4xl font-bold text-slate-900 lg:text-5xl leading-tight tracking-tight">Body Fat Calculator</h1>
      <p class="mt-4 text-lg text-slate-500 max-w-xl leading-relaxed">Estimate your body fat percentage from a few simple measurements — no scales, DEXA, or calipers required.</p>
    </div>
  </section>

  <!-- ── CALCULATOR ─────────────────────────────────────────────── -->
  <section class="bg-background-light px-6 pb-16 lg:px-20" aria-label="Body Fat Calculator">
    <div class="mx-auto max-w-4xl">
      <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">

        <div class="rounded-3xl bg-white border border-slate-100 shadow-sm p-8">
          <h2 class="text-lg font-bold text-slate-900 mb-6">Enter your measurements</h2>

          <div class="flex rounded-xl bg-background-light p-1 mb-6 w-fit" role="group" aria-label="Unit system">
            <button id="unit-metric" class="unit-btn px-5 py-2 rounded-lg text-sm font-semibold bg-white text-slate-900 shadow-sm transition-all" aria-pressed="true">Metric</button>
            <button id="unit-imperial" class="unit-btn px-5 py-2 rounded-lg text-sm font-semibold text-slate-500 hover:text-slate-700 transition-all" aria-pressed="false">Imperial</button>
          </div>

          <form id="bf-form" novalidate>
            <div class="mb-5">
              <label class="block text-sm font-semibold text-slate-700 mb-2">Sex</label>
              <div class="grid grid-cols-2 gap-3">
                <label class="flex items-center justify-center gap-2 py-3 px-4 rounded-xl border border-slate-200 bg-background-light cursor-pointer has-[:checked]:border-violet-500 has-[:checked]:bg-violet-50 has-[:checked]:text-violet-600 transition-all">
                  <input type="radio" name="sex" value="male" checked class="sr-only" />
                  <span class="material-symbols-outlined text-base">male</span>
                  <span class="text-sm font-semibold">Male</span>
                </label>
                <label class="flex items-center justify-center gap-2 py-3 px-4 rounded-xl border border-slate-200 bg-background-light cursor-pointer has-[:checked]:border-violet-500 has-[:checked]:bg-violet-50 has-[:checked]:text-violet-600 transition-all">
                  <input type="radio" name="sex" value="female" class="sr-only" />
                  <span class="material-symbols-outlined text-base">female</span>
                  <span class="text-sm font-semibold">Female</span>
                </label>
              </div>
            </div>

            <div id="height-metric" class="mb-5">
              <label for="height-cm" class="block text-sm font-semibold text-slate-700 mb-2">Height</label>
              <div class="relative">
                <input type="number" id="height-cm" min="50" max="300" placeholder="175" class="w-full rounded-xl border border-slate-200 bg-background-light px-4 py-3.5 pr-14 text-slate-900 placeholder-slate-400 focus:border-violet-500 focus:outline-none focus:ring-2 focus:ring-violet-500/20 transition-all" />
                <span class="absolute right-4 top-1/2 -translate-y-1/2 text-sm font-semibold text-slate-400">cm</span>
              </div>
            </div>
            <div id="height-imperial" class="mb-5 hidden">
              <label class="block text-sm font-semibold text-slate-700 mb-2">Height</label>
              <div class="flex gap-3">
                <div class="relative flex-1">
                  <input type="number" id="height-ft" min="1" max="9" placeholder="5" class="w-full rounded-xl border border-slate-200 bg-background-light px-4 py-3.5 pr-12 text-slate-900 placeholder-slate-400 focus:border-violet-500 focus:outline-none focus:ring-2 focus:ring-violet-500/20 transition-all" />
                  <span class="absolute right-4 top-1/2 -translate-y-1/2 text-sm font-semibold text-slate-400">ft</span>
                </div>
                <div class="relative flex-1">
                  <input type="number" id="height-in" min="0" max="11" placeholder="9" class="w-full rounded-xl border border-slate-200 bg-background-light px-4 py-3.5 pr-12 text-slate-900 placeholder-slate-400 focus:border-violet-500 focus:outline-none focus:ring-2 focus:ring-violet-500/20 transition-all" />
                  <span class="absolute right-4 top-1/2 -translate-y-1/2 text-sm font-semibold text-slate-400">in</span>
                </div>
              </div>
            </div>

            <div id="weight-metric" class="mb-5">
              <label for="weight-kg" class="block text-sm font-semibold text-slate-700 mb-2">Weight</label>
              <div class="relative">
                <input type="number" id="weight-kg" min="10" max="500" placeholder="70" class="w-full rounded-xl border border-slate-200 bg-background-light px-4 py-3.5 pr-12 text-slate-900 placeholder-slate-400 focus:border-violet-500 focus:outline-none focus:ring-2 focus:ring-violet-500/20 transition-all" />
                <span class="absolute right-4 top-1/2 -translate-y-1/2 text-sm font-semibold text-slate-400">kg</span>
              </div>
            </div>
            <div id="weight-imperial" class="mb-5 hidden">
              <label for="weight-lbs" class="block text-sm font-semibold text-slate-700 mb-2">Weight</label>
              <div class="relative">
                <input type="number" id="weight-lbs" min="20" max="1100" placeholder="154" class="w-full rounded-xl border border-slate-200 bg-background-light px-4 py-3.5 pr-14 text-slate-900 placeholder-slate-400 focus:border-violet-500 focus:outline-none focus:ring-2 focus:ring-violet-500/20 transition-all" />
                <span class="absolute right-4 top-1/2 -translate-y-1/2 text-sm font-semibold text-slate-400">lbs</span>
              </div>
            </div>

            <div class="mb-5">
              <label for="neck" class="block text-sm font-semibold text-slate-700 mb-2">Neck circumference</label>
              <div class="relative">
                <input type="number" id="neck" step="0.1" placeholder="38" class="w-full rounded-xl border border-slate-200 bg-background-light px-4 py-3.5 pr-14 text-slate-900 placeholder-slate-400 focus:border-violet-500 focus:outline-none focus:ring-2 focus:ring-violet-500/20 transition-all" />
                <span id="neck-unit" class="absolute right-4 top-1/2 -translate-y-1/2 text-sm font-semibold text-slate-400">cm</span>
              </div>
            </div>

            <div class="mb-5">
              <label for="waist" class="block text-sm font-semibold text-slate-700 mb-2">Waist circumference</label>
              <div class="relative">
                <input type="number" id="waist" step="0.1" placeholder="85" class="w-full rounded-xl border border-slate-200 bg-background-light px-4 py-3.5 pr-14 text-slate-900 placeholder-slate-400 focus:border-violet-500 focus:outline-none focus:ring-2 focus:ring-violet-500/20 transition-all" />
                <span id="waist-unit" class="absolute right-4 top-1/2 -translate-y-1/2 text-sm font-semibold text-slate-400">cm</span>
              </div>
            </div>

            <div id="hip-group" class="mb-6 hidden">
              <label for="hip" class="block text-sm font-semibold text-slate-700 mb-2">Hip circumference</label>
              <div class="relative">
                <input type="number" id="hip" step="0.1" placeholder="95" class="w-full rounded-xl border border-slate-200 bg-background-light px-4 py-3.5 pr-14 text-slate-900 placeholder-slate-400 focus:border-violet-500 focus:outline-none focus:ring-2 focus:ring-violet-500/20 transition-all" />
                <span id="hip-unit" class="absolute right-4 top-1/2 -translate-y-1/2 text-sm font-semibold text-slate-400">cm</span>
              </div>
            </div>

            <p id="bf-error" class="hidden text-sm text-red-600 bg-red-50 border border-red-100 rounded-xl px-4 py-3 mb-4"></p>
            <button type="submit" class="w-full py-4 rounded-xl bg-violet-500 text-white font-bold text-base hover:bg-violet-600 transition-all shadow-lg shadow-violet-500/25 hover:-translate-y-0.5">Calculate body fat</button>
          </form>
        </div>

        <div class="rounded-3xl border border-slate-100 bg-white shadow-sm p-8 flex flex-col" aria-live="polite">
          <div id="results-placeholder" class="flex flex-col items-center justify-center h-full min-h-48 text-center">
            <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-slate-50 mb-4">
              <span class="material-symbols-outlined text-slate-300 text-3xl">straighten</span>
            </div>
            <p class="text-sm text-slate-400 max-w-xs">Enter your measurements to see your estimated body fat percentage.</p>
          </div>
          <div id="results-content" class="hidden">
            <div class="flex items-center justify-between mb-2">
              <h2 class="text-lg font-bold text-slate-900">Your body fat</h2>
              <button id="reset-btn" class="text-xs text-slate-400 hover:text-violet-500 transition-colors flex items-center gap-1">
                <span class="material-symbols-outlined text-sm">refresh</span> Reset
              </button>
            </div>
            <div class="text-center my-6">
              <div id="bf-value" class="text-7xl font-bold text-slate-900 tabular-nums">—</div>
              <div class="mt-1 text-sm font-semibold text-slate-500">% body fat</div>
              <div id="bf-category" class="mt-3 inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-sm font-semibold"></div>
            </div>
            <div class="grid grid-cols-2 gap-3 mb-6">
              <div class="rounded-2xl bg-background-light p-4">
                <p class="text-xs text-slate-500 mb-1">Fat mass</p>
                <p id="fat-mass" class="text-base font-bold text-slate-900">—</p>
              </div>
              <div class="rounded-2xl bg-background-light p-4">
                <p class="text-xs text-slate-500 mb-1">Lean mass</p>
                <p id="lean-mass" class="text-base font-bold text-slate-900">—</p>
              </div>
              <div class="rounded-2xl bg-background-light p-4 col-span-2">
                <p class="text-xs text-slate-500 mb-1">Healthy range for you</p>
                <p id="healthy-range" class="text-base font-bold text-slate-900">—</p>
              </div>
            </div>
            <a href="#" class="flex items-center justify-center gap-2 w-full py-3.5 rounded-xl bg-slate-900 text-white font-bold text-sm hover:bg-slate-700 transition-all" data-analytics-store="ios" data-analytics-placement="bf_result">
              <span class="material-symbols-outlined text-base">show_chart</span>Track your body fat over time in SlayCal
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── CATEGORIES ─────────────────────────────────────────────── -->
  <section class="bg-white px-6 py-16 lg:px-20" aria-labelledby="bf-cats-title">
    <div class="mx-auto max-w-4xl">
      <h2 id="bf-cats-title" class="text-2xl font-bold text-slate-900 mb-2">Body fat categories</h2>
      <p class="text-slate-500 mb-8">Typical ranges defined by the American Council on Exercise (ACE).</p>
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
        <div class="rounded-3xl border border-slate-100 p-6">
          <h3 class="font-bold text-slate-900 mb-4 flex items-center gap-2"><span class="material-symbols-outlined text-blue-500">male</span> Men</h3>
          <div class="space-y-2">
            {[
              { range: '2–5%',   label: 'Essential fat', color: 'bg-blue-50 text-blue-700' },
              { range: '6–13%',  label: 'Athletes',      color: 'bg-green-50 text-green-700' },
              { range: '14–17%', label: 'Fitness',       color: 'bg-emerald-50 text-emerald-700' },
              { range: '18–24%', label: 'Average',       color: 'bg-yellow-50 text-yellow-700' },
              { range: '25%+',   label: 'Obese',         color: 'bg-red-50 text-red-700' },
            ].map(({ range, label, color }) => (
              <div class={`flex items-center justify-between px-4 py-2.5 rounded-xl ${color}`}>
                <span class="text-sm font-semibold">{label}</span>
                <span class="text-sm font-bold tabular-nums">{range}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="rounded-3xl border border-slate-100 p-6">
          <h3 class="font-bold text-slate-900 mb-4 flex items-center gap-2"><span class="material-symbols-outlined text-pink-500">female</span> Women</h3>
          <div class="space-y-2">
            {[
              { range: '10–13%', label: 'Essential fat', color: 'bg-blue-50 text-blue-700' },
              { range: '14–20%', label: 'Athletes',      color: 'bg-green-50 text-green-700' },
              { range: '21–24%', label: 'Fitness',       color: 'bg-emerald-50 text-emerald-700' },
              { range: '25–31%', label: 'Average',       color: 'bg-yellow-50 text-yellow-700' },
              { range: '32%+',   label: 'Obese',         color: 'bg-red-50 text-red-700' },
            ].map(({ range, label, color }) => (
              <div class={`flex items-center justify-between px-4 py-2.5 rounded-xl ${color}`}>
                <span class="text-sm font-semibold">{label}</span>
                <span class="text-sm font-bold tabular-nums">{range}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
      <div class="mt-8 rounded-2xl bg-amber-50 border border-amber-100 p-5 flex gap-3">
        <span class="material-symbols-outlined text-amber-500 text-xl shrink-0 mt-0.5">info</span>
        <p class="text-sm text-slate-600 leading-relaxed"><strong class="text-slate-800">This is an estimate.</strong> The US Navy method has a typical accuracy of ±3% vs. DEXA scans. Measure in the morning, relaxed, tape snug but not compressed. Track the trend, not a single number.</p>
      </div>
    </div>
  </section>

  <!-- ── SLAYCAL CTA ────────────────────────────────────────────── -->
  <section class="relative overflow-hidden bg-gradient-to-br from-violet-500 via-purple-500 to-fuchsia-500 px-6 py-20 lg:px-20" aria-labelledby="cta-bf-title">
    <div class="relative mx-auto max-w-3xl text-center">
      <h2 id="cta-bf-title" class="text-3xl font-bold text-white lg:text-4xl leading-tight">Body composition beats the scale.</h2>
      <p class="mt-4 text-white/80 max-w-xl mx-auto leading-relaxed">SlayCal helps you hit protein targets that preserve muscle while you lose fat — the only way body composition actually changes.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="#" class="flex items-center gap-2 px-7 py-3.5 rounded-2xl bg-white text-slate-900 font-bold hover:bg-slate-50 transition-all shadow-xl" data-analytics-store="ios" data-analytics-placement="bf_cta">
          <svg class="w-5 h-5 fill-slate-900 shrink-0" viewBox="0 0 24 24"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
          Download free on iOS
        </a>
        <a href="#" class="flex items-center gap-2 px-7 py-3.5 rounded-2xl bg-white/15 border-2 border-white/30 text-white font-bold hover:bg-white/25 transition-all" data-analytics-store="android" data-analytics-placement="bf_cta">
          <svg class="w-5 h-5 fill-white shrink-0" viewBox="0 0 24 24"><path d="M3.18 23.76A2 2 0 0 1 2 22V2a2 2 0 0 1 1.18-1.76l11.65 11.76zm15.49-8.58L16.07 13.5 3.64.05l.88-.05 14.15 7.87a2 2 0 0 1 0 3.31zM3.64 23.95 16.07 10.5l2.6 1.55-14.15 7.87z"/></svg>
          Get it on Google Play
        </a>
      </div>
      <p class="mt-5 text-xs text-white/60">Free · 500 scan credits · No credit card</p>
    </div>
  </section>

  <!-- ── OTHER CALCULATORS ──────────────────────────────────────── -->
  <section class="bg-white px-6 py-16 lg:px-20" aria-labelledby="more-bf-title">
    <div class="mx-auto max-w-4xl">
      <h2 id="more-bf-title" class="text-xl font-bold text-slate-900 mb-6">More free calculators</h2>
      <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
        {[
          { href: '/bmi-calculator', icon: 'monitor_weight', label: 'BMI Calculator', desc: 'Check if your weight is in a healthy range.' },
          { href: '/calorie-calculator', icon: 'local_fire_department', label: 'Calorie Calculator', desc: 'Find your daily calorie target.' },
          { href: '/macro-calculator', icon: 'pie_chart', label: 'Macro Calculator', desc: 'Break calories into protein, carbs, fat.' },
        ].map(({ href, icon, label, desc }) => (
          <a href={href} class="flex items-center gap-4 p-4 rounded-2xl border border-slate-100 hover:border-violet-200 hover:bg-violet-50/50 transition-all group">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-violet-100">
              <span class="material-symbols-outlined text-violet-600 text-xl">{icon}</span>
            </div>
            <div>
              <p class="text-sm font-semibold text-slate-800 group-hover:text-violet-600 transition-colors">{label}</p>
              <p class="text-xs text-slate-400">{desc}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</main>

<script>
  const metricBtn = document.getElementById('unit-metric')!;
  const imperialBtn = document.getElementById('unit-imperial')!;
  const form = document.getElementById('bf-form')!;
  const placeholder = document.getElementById('results-placeholder')!;
  const resultsContent = document.getElementById('results-content')!;
  const resetBtn = document.getElementById('reset-btn')!;
  const hipGroup = document.getElementById('hip-group')!;
  const neckUnitEl = document.getElementById('neck-unit')!;
  const waistUnitEl = document.getElementById('waist-unit')!;
  const hipUnitEl = document.getElementById('hip-unit')!;
  let isMetric = true;

  function setUnit(metric: boolean) {
    isMetric = metric;
    metricBtn.setAttribute('aria-pressed', String(metric));
    imperialBtn.setAttribute('aria-pressed', String(!metric));
    const active = ['bg-white', 'text-slate-900', 'shadow-sm'];
    if (metric) {
      metricBtn.classList.add(...active); metricBtn.classList.remove('text-slate-500');
      imperialBtn.classList.remove(...active); imperialBtn.classList.add('text-slate-500');
    } else {
      imperialBtn.classList.add(...active); imperialBtn.classList.remove('text-slate-500');
      metricBtn.classList.remove(...active); metricBtn.classList.add('text-slate-500');
    }
    document.getElementById('height-metric')!.classList.toggle('hidden', !metric);
    document.getElementById('height-imperial')!.classList.toggle('hidden', metric);
    document.getElementById('weight-metric')!.classList.toggle('hidden', !metric);
    document.getElementById('weight-imperial')!.classList.toggle('hidden', metric);
    const u = metric ? 'cm' : 'in';
    neckUnitEl.textContent = u;
    waistUnitEl.textContent = u;
    hipUnitEl.textContent = u;
  }

  metricBtn.addEventListener('click', () => setUnit(true));
  imperialBtn.addEventListener('click', () => setUnit(false));

  // Toggle hip input by sex
  document.querySelectorAll('input[name="sex"]').forEach((el) => {
    el.addEventListener('change', () => {
      const sexInput = document.querySelector('input[name="sex"]:checked') as HTMLInputElement | null;
      hipGroup.classList.toggle('hidden', sexInput?.value !== 'female');
    });
  });

  function bfCategory(sex: 'male' | 'female', pct: number): { label: string; color: string } {
    if (sex === 'male') {
      if (pct < 6)  return { label: 'Essential fat', color: 'bg-blue-100 text-blue-700' };
      if (pct < 14) return { label: 'Athletes',      color: 'bg-green-100 text-green-700' };
      if (pct < 18) return { label: 'Fitness',       color: 'bg-emerald-100 text-emerald-700' };
      if (pct < 25) return { label: 'Average',       color: 'bg-yellow-100 text-yellow-700' };
      return { label: 'Obese', color: 'bg-red-100 text-red-700' };
    } else {
      if (pct < 14) return { label: 'Essential fat', color: 'bg-blue-100 text-blue-700' };
      if (pct < 21) return { label: 'Athletes',      color: 'bg-green-100 text-green-700' };
      if (pct < 25) return { label: 'Fitness',       color: 'bg-emerald-100 text-emerald-700' };
      if (pct < 32) return { label: 'Average',       color: 'bg-yellow-100 text-yellow-700' };
      return { label: 'Obese', color: 'bg-red-100 text-red-700' };
    }
  }

  const errorEl = document.getElementById('bf-error')!;
  function showError(msg: string) {
    errorEl.textContent = msg;
    errorEl.classList.remove('hidden');
  }
  function clearError() {
    errorEl.classList.add('hidden');
  }

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    clearError();
    const sexInput = document.querySelector('input[name="sex"]:checked') as HTMLInputElement | null;
    const sex: 'male' | 'female' = sexInput?.value === 'female' ? 'female' : 'male';

    let heightCm: number, weightKg: number;
    if (isMetric) {
      heightCm = parseFloat((document.getElementById('height-cm') as HTMLInputElement).value);
      weightKg = parseFloat((document.getElementById('weight-kg') as HTMLInputElement).value);
      if (!heightCm || !weightKg) { showError('Please enter your height and weight.'); return; }
    } else {
      const ft = parseFloat((document.getElementById('height-ft') as HTMLInputElement).value) || 0;
      const inches = parseFloat((document.getElementById('height-in') as HTMLInputElement).value) || 0;
      const lbs = parseFloat((document.getElementById('weight-lbs') as HTMLInputElement).value);
      if ((!ft && !inches) || !lbs) { showError('Please enter your height and weight.'); return; }
      heightCm = ((ft * 12) + inches) * 2.54;
      weightKg = lbs * 0.453592;
    }

    const neckRaw = parseFloat((document.getElementById('neck') as HTMLInputElement).value);
    const waistRaw = parseFloat((document.getElementById('waist') as HTMLInputElement).value);
    if (!neckRaw || !waistRaw) { showError('Please enter your neck and waist measurements.'); return; }
    const neckCm = isMetric ? neckRaw : neckRaw * 2.54;
    const waistCm = isMetric ? waistRaw : waistRaw * 2.54;

    if (waistCm <= neckCm) { showError('Waist measurement must be larger than neck measurement.'); return; }

    let bf: number;
    if (sex === 'male') {
      bf = 495 / (1.0324 - 0.19077 * Math.log10(waistCm - neckCm) + 0.15456 * Math.log10(heightCm)) - 450;
    } else {
      const hipRaw = parseFloat((document.getElementById('hip') as HTMLInputElement).value);
      if (!hipRaw) { showError('Please enter your hip measurement.'); return; }
      const hipCm = isMetric ? hipRaw : hipRaw * 2.54;
      bf = 495 / (1.29579 - 0.35004 * Math.log10(waistCm + hipCm - neckCm) + 0.22100 * Math.log10(heightCm)) - 450;
    }

    if (!isFinite(bf) || bf <= 0 || bf > 70) { showError('Could not calculate — please double-check your measurements and try again.'); return; }
    const bfRounded = Math.round(bf * 10) / 10;
    const fatMassKg = weightKg * (bf / 100);
    const leanMassKg = weightKg - fatMassKg;

    const weightUnit = isMetric ? 'kg' : 'lbs';
    const toDisplayWeight = (kg: number) => isMetric ? kg : kg * 2.2046;

    const healthyLow = sex === 'male' ? 8 : 18;
    const healthyHigh = sex === 'male' ? 19 : 25;
    const healthyLowKg = weightKg * (healthyLow / 100) + (weightKg - weightKg * (bf / 100) - weightKg * (healthyLow / 100) + weightKg * (healthyLow / 100)); // just a simple display of % range
    // Show as % range, not weight - simpler:
    const healthyRangeLabel = `${healthyLow}–${healthyHigh}%`;

    const cat = bfCategory(sex, bf);
    document.getElementById('bf-value')!.textContent = String(bfRounded);
    const catEl = document.getElementById('bf-category')!;
    catEl.textContent = cat.label;
    catEl.className = `mt-3 inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-sm font-semibold ${cat.color}`;
    document.getElementById('fat-mass')!.textContent = `${toDisplayWeight(fatMassKg).toFixed(1)} ${weightUnit}`;
    document.getElementById('lean-mass')!.textContent = `${toDisplayWeight(leanMassKg).toFixed(1)} ${weightUnit}`;
    document.getElementById('healthy-range')!.textContent = healthyRangeLabel;

    placeholder.classList.add('hidden');
    resultsContent.classList.remove('hidden');
  });

  resetBtn.addEventListener('click', () => {
    resultsContent.classList.add('hidden');
    placeholder.classList.remove('hidden');
    (form as HTMLFormElement).reset();
    hipGroup.classList.add('hidden');
    clearError();
  });
</script>
