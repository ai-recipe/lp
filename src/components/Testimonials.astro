---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const { testimonials } = t;

const avatarColors = [
  'from-orange-200 to-orange-300',
  'from-sky-200 to-sky-300',
  'from-emerald-200 to-emerald-300',
];
---

<section class="py-24 px-6 lg:px-20" aria-labelledby="testimonials-title">
  <div class="mx-auto max-w-7xl">

    <!-- Section header -->
    <div class="mb-16 text-center max-w-2xl mx-auto">
      <span class="inline-block rounded-full bg-primary/10 px-4 py-1 text-xs font-bold uppercase tracking-widest text-primary mb-4">
        {testimonials.section_label}
      </span>
      <h2 id="testimonials-title" class="text-3xl font-bold tracking-tight lg:text-4xl">
        {testimonials.title}
      </h2>
      <p class="mt-4 text-slate-600 text-lg">{testimonials.subtitle}</p>
    </div>

    <!-- Testimonial cards -->
    <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
      {testimonials.items.map((item, i) => (
        <figure class="flex flex-col gap-6 rounded-2xl border border-slate-100 bg-white p-8 shadow-sm hover:shadow-xl hover:shadow-primary/5 transition-all duration-300 hover:-translate-y-1">
          <!-- Stars -->
          <div class="flex gap-1" role="img" aria-label={`${item.rating} out of 5 stars`}>
            {Array.from({ length: item.rating }).map(() => (
              <svg class="w-4 h-4 fill-amber-400" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>

          <!-- Quote -->
          <blockquote class="flex-1">
            <p class="text-slate-700 leading-relaxed">"{item.text}"</p>
          </blockquote>

          <!-- Author -->
          <figcaption class="flex items-center gap-3">
            <div
              class={`h-10 w-10 rounded-full bg-gradient-to-br ${avatarColors[i]} flex items-center justify-center shrink-0`}
              aria-hidden="true"
            >
              <span class="text-sm font-bold text-white">{item.name.charAt(0)}</span>
            </div>
            <div>
              <p class="text-sm font-bold text-slate-900">{item.name}</p>
              <p class="text-xs text-slate-500">{item.role}</p>
            </div>
          </figcaption>
        </figure>
      ))}
    </div>

    <!-- App store rating badges -->
    <div class="mt-16 flex flex-wrap justify-center gap-8">
      <div class="flex items-center gap-3 px-6 py-4 rounded-xl bg-white border border-slate-100 shadow-sm">
        <svg class="w-8 h-8 fill-slate-900 shrink-0" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
        </svg>
        <div>
          <div class="flex gap-0.5 mb-0.5">
            {[1,2,3,4,5].map(() => (
              <svg class="w-3 h-3 fill-amber-400" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>
          <p class="text-xs font-bold text-slate-900">4.8 on App Store</p>
        </div>
      </div>

      <div class="flex items-center gap-3 px-6 py-4 rounded-xl bg-white border border-slate-100 shadow-sm">
        <svg class="w-8 h-8 fill-primary shrink-0" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M3.18 23.76A2 2 0 0 1 2 22V2a2 2 0 0 1 1.18-1.76l11.65 11.76zm15.49-8.58L16.07 13.5 3.64.05l.88-.05 14.15 7.87a2 2 0 0 1 0 3.31zM3.64 23.95 16.07 10.5l2.6 1.55-14.15 7.87z"/>
        </svg>
        <div>
          <div class="flex gap-0.5 mb-0.5">
            {[1,2,3,4,5].map(() => (
              <svg class="w-3 h-3 fill-amber-400" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>
          <p class="text-xs font-bold text-slate-900">4.8 on Google Play</p>
        </div>
      </div>
    </div>
  </div>
</section>
