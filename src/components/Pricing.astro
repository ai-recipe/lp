---
// Pricing Section
const plans = [
  {
    name: 'Monthly',
    price: '$9.99',
    period: '/mo',
    popular: false,
    features: ['Unlimited AI Scans', 'Full Macro Analytics', 'Ad-free experience'],
    ctaLabel: 'Choose Plan',
    ctaClass: 'w-full py-4 rounded-full border-2 border-primary/20 font-bold hover:bg-primary/5 transition-all',
    cardClass: 'flex flex-col rounded-lg bg-white p-8 shadow-sm transition-all hover:shadow-xl',
  },
  {
    name: 'Yearly',
    price: '$79.99',
    period: '/yr',
    popular: true,
    badge: 'MOST POPULAR',
    note: 'Save 33% per year',
    features: ['Everything in Monthly', 'Priority AI Processing', 'Early access to new features'],
    ctaLabel: 'Get Started',
    ctaClass: 'w-full py-4 rounded-full bg-primary text-white font-bold shadow-lg shadow-primary/30 transition-all hover:scale-105',
    cardClass: 'relative flex flex-col rounded-lg bg-white p-8 shadow-xl ring-2 ring-primary',
  },
  {
    name: 'Lifetime',
    price: '$199',
    period: 'once',
    popular: false,
    features: ['All Premium Features Forever', 'VIP Customer Support', 'Personalized AI Coaching'],
    ctaLabel: 'Buy Once',
    ctaClass: 'w-full py-4 rounded-full border-2 border-primary/20 font-bold hover:bg-primary/5 transition-all',
    cardClass: 'flex flex-col rounded-lg bg-white p-8 shadow-sm transition-all hover:shadow-xl',
  },
];
---

<section class="bg-primary/5 py-24 px-6 lg:px-20" id="pricing">
  <div class="mx-auto max-w-7xl">
    <div class="mb-16 text-center">
      <h2 class="text-3xl font-bold tracking-tight lg:text-4xl">Chef AI Premium</h2>
      <p class="mt-4 text-slate-600">Elevate your culinary skills with advanced AI tools.</p>
    </div>

    <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
      {plans.map((plan) => (
        <div class={plan.cardClass}>
          {plan.popular && (
            <div class="absolute -top-4 left-1/2 -translate-x-1/2 rounded-full bg-primary px-4 py-1 text-xs font-bold text-white">
              {plan.badge}
            </div>
          )}
          <div class="mb-8">
            <h3 class="text-xl font-bold">{plan.name}</h3>
            <div class="mt-4 flex items-baseline gap-1">
              <span class="text-4xl font-bold">{plan.price}</span>
              <span class="text-slate-500">{plan.period}</span>
            </div>
            {plan.note && (
              <p class="mt-2 text-xs font-bold text-primary">{plan.note}</p>
            )}
          </div>
          <ul class="mb-8 flex-1 space-y-4">
            {plan.features.map((feat) => (
              <li class="flex items-center gap-3 text-sm">
                <span class="material-symbols-outlined text-green-500 text-lg">check_circle</span>
                <span>{feat}</span>
              </li>
            ))}
          </ul>
          <button class={plan.ctaClass}>{plan.ctaLabel}</button>
        </div>
      ))}
    </div>
  </div>
</section>
